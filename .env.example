# ─────────────────────────────────────────────────────────
# Artal Sentinel — متغيرات البيئة
# انسخ هذا الملف إلى .env على السيرفر وعدّل القيم
# ─────────────────────────────────────────────────────────

# المنفذ (اختياري — الافتراضي 3000)
PORT=3000

# مسار قاعدة البيانات خارج مجلد المشروع (مهم جداً على السيرفر)
DB_PATH=/var/artal-sentinel/artal.db

# مسار ملفات الرفع خارج مجلد المشروع
UPLOADS_PATH=/var/artal-sentinel/uploads

# مفتاح تشفير الجلسات (غيّره لقيمة عشوائية طويلة)
SESSION_SECRET=change-this-to-a-long-random-secret-string
