# ─────────────────────────────────────────────────────────
# Artal Sentinel — متغيرات البيئة
# انسخ هذا الملف إلى .env على السيرفر وعدّل القيم
# ─────────────────────────────────────────────────────────

# المنفذ (اختياري — الافتراضي 3000)
PORT=3000

# ─── إعدادات MySQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=u376291233_apply
DB_PASS=YOUR_MYSQL_PASSWORD_HERE
DB_NAME=u376291233_apply

# مسار ملفات الرفع — استخدم مساراً داخل home مستخدمك
# مثال Hostinger: /home/u376291233/uploads
# إذا تركته فارغاً يُحفظ داخل مجلد المشروع (uploads/)
UPLOADS_PATH=/home/u376291233/uploads

# مفتاح تشفير الجلسات — يجب أن يكون عشوائياً طويلاً (لا تستخدم القيمة الافتراضية!)
# لتوليد مفتاح: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-secret-string

# فعّل الـ Secure Cookie — فقط على السيرفر (HTTPS). لا تضعه في بيئة التطوير المحلية
SECURE_COOKIE=true

# مفتاح API النظام الخارجي (artalsys.com)
EXT_API_SECRET=artal@NID%2026
