<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>إدارة المستخدمين — أرتال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f2f4f6; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    input, select { background:white; border:1px solid #e0e3e5; border-radius:0.75rem;
      padding:0.5rem 0.75rem; font-size:0.875rem; width:100%; outline:none; }
    input:focus, select:focus { border-color:#7594ca; }
    .panel { display:none; }
    .panel.open { display:block; }
  </style>
</head>
<body class="text-[#191c1e]">
<%- include('partials/sidebar', { currentPage: 'users' }) %>

<div class="mr-64 min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-[#eceef0] px-8 py-5 flex items-center justify-between sticky top-0 z-30">
    <div>
      <h1 class="text-xl font-bold text-[#001736]">إدارة المستخدمين</h1>
      <p class="text-xs text-[#43474f] mt-0.5">إجمالي الحسابات: <strong><%= users.length %></strong></p>
    </div>
    <button onclick="togglePanel('create-panel')"
            class="bg-[#001736] text-white text-sm font-semibold px-5 py-2.5 rounded-xl flex items-center gap-2 hover:bg-[#002b5b] transition-colors">
      <span class="material-symbols-outlined text-base">person_add</span>
      إضافة مستخدم
    </button>
  </header>

  <main class="p-8 space-y-6">

    <!-- Alerts -->
    <% if (success === '1') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span> تم إنشاء المستخدم بنجاح.
    </div>
    <% } else if (success === '2') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span> تم تحديث المستخدم بنجاح.
    </div>
    <% } else if (success === '3') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span> تم تغيير كلمة المرور بنجاح.
    </div>
    <% } else if (success === '4') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span> تم حذف المستخدم.
    </div>
    <% } %>
    <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-3 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">error</span> <%= error %>
    </div>
    <% } %>

    <!-- Create User Panel -->
    <div id="create-panel" class="panel bg-white rounded-2xl p-7 border-2 border-[#001736]/10">
      <h2 class="font-bold text-[#001736] text-base mb-5 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">person_add</span>
        إنشاء مستخدم جديد
      </h2>
      <form method="POST" action="/admin/users" class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div>
          <label class="block text-xs text-[#43474f] font-semibold mb-1">اسم المستخدم</label>
          <input type="text" name="username" placeholder="مثال: ahmed" required minlength="3">
        </div>
        <div>
          <label class="block text-xs text-[#43474f] font-semibold mb-1">كلمة المرور</label>
          <input type="password" name="password" placeholder="8 أحرف على الأقل" required minlength="8">
        </div>
        <div>
          <label class="block text-xs text-[#43474f] font-semibold mb-1">الدور</label>
          <select name="role">
            <option value="employee">موظف</option>
            <option value="manager">مدير</option>
          </select>
        </div>
        <div class="flex items-end gap-2">
          <button type="submit"
                  class="flex-1 bg-[#001736] text-white text-sm font-semibold py-2.5 rounded-xl hover:bg-[#002b5b] transition-colors">
            إنشاء
          </button>
          <button type="button" onclick="togglePanel('create-panel')"
                  class="px-4 py-2.5 rounded-xl bg-[#f2f4f6] text-sm text-[#43474f] hover:bg-[#eceef0] transition-colors">
            إلغاء
          </button>
        </div>
      </form>
    </div>

    <!-- Users Table -->
    <div class="bg-white rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-[#f8f9fb] border-b border-[#eceef0]">
            <tr class="text-[#43474f] text-xs">
              <th class="text-right px-6 py-4 font-semibold">المستخدم</th>
              <th class="text-center px-4 py-4 font-semibold">الدور</th>
              <th class="text-center px-4 py-4 font-semibold">الحالة</th>
              <th class="text-right px-4 py-4 font-semibold">آخر دخول</th>
              <th class="text-right px-4 py-4 font-semibold">تاريخ الإنشاء</th>
              <th class="text-center px-4 py-4 font-semibold">العمليات</th>
              <th class="px-4 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#f2f4f6]">
            <% users.forEach(u => { %>
            <tr class="hover:bg-[#f8f9fb] transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full <%= u.id === currentUser ? 'bg-[#ffdf9e]/30' : 'bg-[#f2f4f6]' %> flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-base text-[#43474f]"
                          style="font-variation-settings:'FILL' 1">
                      <%= u.id === currentUser ? 'manage_accounts' : 'person' %>
                    </span>
                  </div>
                  <div>
                    <div class="font-semibold text-[#001736]">
                      <%= u.username %>
                      <% if (u.id === currentUser) { %>
                      <span class="text-[10px] bg-[#ffdf9e]/40 text-[#7a5c00] px-2 py-0.5 rounded-full mr-1 font-normal">أنت</span>
                      <% } %>
                    </div>
                    <div class="text-xs text-[#7594ca]">ID #<%= u.id %></div>
                  </div>
                </div>
              </td>
              <td class="px-4 py-4 text-center">
                <% if (u.role === 'manager') { %>
                <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[#001736] text-white">مدير</span>
                <% } else { %>
                <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-[#f2f4f6] text-[#43474f]">موظف</span>
                <% } %>
              </td>
              <td class="px-4 py-4 text-center">
                <% if (u.is_active) { %>
                <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">نشط</span>
                <% } else { %>
                <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-600">موقوف</span>
                <% } %>
              </td>
              <td class="px-4 py-4 text-[#43474f] text-xs">
                <% if (u.last_login) { %>
                <%= new Date(u.last_login).toLocaleDateString('ar-SA') %>
                <span class="block text-[#7594ca]">
                  <%= new Date(u.last_login).toLocaleTimeString('ar-SA', { hour:'2-digit', minute:'2-digit' }) %>
                </span>
                <% } else { %>
                <span class="text-[#c4c6d0]">لم يسجّل دخولاً</span>
                <% } %>
              </td>
              <td class="px-4 py-4 text-[#43474f] text-xs">
                <%= new Date(u.created_at).toLocaleDateString('ar-SA') %>
              </td>
              <td class="px-4 py-4 text-center">
                <a href="/admin/audit?user=<%= u.username %>"
                   class="inline-flex items-center gap-1 text-xs font-semibold text-[#405f91] hover:underline">
                  <span class="material-symbols-outlined text-sm">bar_chart</span>
                  <%= u.action_count || 0 %>
                </a>
              </td>
              <td class="px-4 py-4">
                <% if (u.id !== currentUser) { %>
                <div class="flex items-center gap-1 justify-end">
                  <!-- Edit Button -->
                  <button onclick="openEdit(<%= u.id %>, '<%= u.username %>', '<%= u.role %>', <%= u.is_active %>)"
                          class="p-2 rounded-lg text-[#43474f] hover:bg-[#f2f4f6] transition-colors" title="تعديل">
                    <span class="material-symbols-outlined text-base">edit</span>
                  </button>
                  <!-- Reset Password Button -->
                  <button onclick="openReset(<%= u.id %>, '<%= u.username %>')"
                          class="p-2 rounded-lg text-[#43474f] hover:bg-[#f2f4f6] transition-colors" title="إعادة تعيين كلمة المرور">
                    <span class="material-symbols-outlined text-base">lock_reset</span>
                  </button>
                  <!-- Delete Button -->
                  <button onclick="confirmDelete(<%= u.id %>, '<%= u.username %>')"
                          class="p-2 rounded-lg text-red-400 hover:bg-red-50 transition-colors" title="حذف">
                    <span class="material-symbols-outlined text-base">delete</span>
                  </button>
                </div>
                <% } else { %>
                <span class="text-xs text-[#c4c6d0]">—</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </main>
</div>

<!-- Edit Modal -->
<div id="edit-modal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center flex">
  <div class="bg-white rounded-2xl p-8 w-full max-w-sm mx-4 shadow-2xl">
    <h3 class="font-bold text-[#001736] text-base mb-5 flex items-center gap-2">
      <span class="material-symbols-outlined text-lg">edit</span>
      تعديل المستخدم: <span id="edit-username" class="text-[#405f91]"></span>
    </h3>
    <form id="edit-form" method="POST" class="space-y-4">
      <div>
        <label class="block text-xs text-[#43474f] font-semibold mb-1">الدور</label>
        <select name="role" id="edit-role">
          <option value="employee">موظف</option>
          <option value="manager">مدير</option>
        </select>
      </div>
      <div>
        <label class="block text-xs text-[#43474f] font-semibold mb-1">الحالة</label>
        <select name="is_active" id="edit-active">
          <option value="1">نشط</option>
          <option value="0">موقوف</option>
        </select>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit"
                class="flex-1 bg-[#001736] text-white text-sm font-semibold py-3 rounded-xl hover:bg-[#002b5b] transition-colors">
          حفظ
        </button>
        <button type="button" onclick="closeModal('edit-modal')"
                class="px-5 py-3 rounded-xl bg-[#f2f4f6] text-sm text-[#43474f] hover:bg-[#eceef0] transition-colors">
          إلغاء
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Reset Password Modal -->
<div id="reset-modal" class="fixed inset-0 bg-black/40 z-50 hidden items-center justify-center flex">
  <div class="bg-white rounded-2xl p-8 w-full max-w-sm mx-4 shadow-2xl">
    <h3 class="font-bold text-[#001736] text-base mb-5 flex items-center gap-2">
      <span class="material-symbols-outlined text-lg">lock_reset</span>
      إعادة تعيين كلمة مرور: <span id="reset-username" class="text-[#405f91]"></span>
    </h3>
    <form id="reset-form" method="POST" class="space-y-4">
      <div>
        <label class="block text-xs text-[#43474f] font-semibold mb-1">كلمة المرور الجديدة</label>
        <input type="password" name="new_password" placeholder="8 أحرف على الأقل" required minlength="8">
      </div>
      <div>
        <label class="block text-xs text-[#43474f] font-semibold mb-1">تأكيد كلمة المرور</label>
        <input type="password" name="confirm_password" placeholder="أعد كتابة كلمة المرور" required minlength="8">
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit"
                class="flex-1 bg-[#002b5b] text-white text-sm font-semibold py-3 rounded-xl hover:bg-[#003a7a] transition-colors">
          تغيير كلمة المرور
        </button>
        <button type="button" onclick="closeModal('reset-modal')"
                class="px-5 py-3 rounded-xl bg-[#f2f4f6] text-sm text-[#43474f] hover:bg-[#eceef0] transition-colors">
          إلغاء
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Form (hidden) -->
<form id="delete-form" method="POST" class="hidden">
  <input type="hidden" name="_method" value="DELETE">
</form>

<script>
function togglePanel(id) {
  document.getElementById(id).classList.toggle('open');
}
function closeModal(id) {
  document.getElementById(id).classList.add('hidden');
  document.getElementById(id).classList.remove('flex');
}
function openModal(id) {
  document.getElementById(id).classList.remove('hidden');
  document.getElementById(id).classList.add('flex');
}
function openEdit(id, username, role, isActive) {
  document.getElementById('edit-username').textContent = username;
  document.getElementById('edit-form').action = `/admin/users/${id}/update`;
  document.getElementById('edit-role').value   = role;
  document.getElementById('edit-active').value = isActive ? '1' : '0';
  openModal('edit-modal');
}
function openReset(id, username) {
  document.getElementById('reset-username').textContent = username;
  document.getElementById('reset-form').action = `/admin/users/${id}/password`;
  openModal('reset-modal');
}
function confirmDelete(id, username) {
  if (!confirm(`هل أنت متأكد من حذف المستخدم "${username}"؟`)) return;
  const form = document.getElementById('delete-form');
  form.action = `/admin/users/${id}/delete`;
  form.submit();
}
// Close modal on backdrop click
['edit-modal','reset-modal'].forEach(id => {
  document.getElementById(id).addEventListener('click', function(e) {
    if (e.target === this) closeModal(id);
  });
});
</script>
</body>
</html>
