    body { background-color:#f8f9fb; font-family:'Inter',sans-serif; }
    h1,h2,h3 { font-family:'Manrope',sans-serif; }

    /* حقل بحالة خطأ */
    .input-wrap.has-error input:not([type="radio"]),
    .input-wrap.has-error select {
      background-color: #fff5f5 !important;
      box-shadow: 0 0 0 2px #fca5a5 !important;
    }
    /* خطأ في مجموعة راديو */
    #wrap-gender.has-error,
    #wrap-has_car.has-error,
    #wrap-has_license.has-error,
