          </div>

        </div>

        <!-- File Uploads -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-on-surface-variant">
              السيرة الذاتية (CV) <span class="text-error">*</span>
            </label>
            <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-outline-variant/30 rounded-xl bg-surface-container-low hover:bg-surface-container transition-colors cursor-pointer group"
                   id="cvLabel">
              <div class="flex flex-col items-center justify-center pt-5 pb-6">
                <span class="material-symbols-outlined text-primary mb-2 text-3xl group-hover:scale-110 transition-transform">upload_file</span>
                <p class="text-xs text-slate-500" id="cvName">PDF, DOC, JPG, PNG (الحد الأقصى 5MB)</p>
              </div>
              <input class="hidden" name="cv" type="file" accept=".pdf,.doc,.docx,.jpg,.jpeg,.png"
                     required
                     onchange="updateFileName(this,'cvName')"/>
            </label>
          </div>
          <div class="space-y-2">
            <label class="block text-sm font-semibold text-on-surface-variant">
              صورة الهوية الوطنية <span class="text-error">*</span>
            </label>
            <label class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-outline-variant/30 rounded-xl bg-surface-container-low hover:bg-surface-container transition-colors cursor-pointer group"
                   id="idLabel">
              <div class="flex flex-col items-center justify-center pt-5 pb-6">
                <span class="material-symbols-outlined text-primary mb-2 text-3xl group-hover:scale-110 transition-transform">badge</span>
                <p class="text-xs text-slate-500" id="idName">JPG, PNG, PDF (صورة واضحة)</p>
              </div>
              <input class="hidden" name="id_image" type="file" accept=".jpg,.jpeg,.png,.webp,.pdf"
                     required
                     onchange="updateFileName(this,'idName')"/>
            </label>
          </div>
        </div>

        <!-- Submit Button -->
        <div class="pt-6">
          <button class="w-full bg-gradient-to-r from-primary to-primary-container text-white font-bold py-4 rounded-lg flex items-center justify-center gap-3 hover:opacity-90 transition-all shadow-lg active:scale-[0.98]"
                  type="submit" id="submitBtn">
            إرسال الطلب
            <span class="material-symbols-outlined">send</span>
          </button>
          <p class="text-xs text-center text-slate-400 mt-3">
            <span class="text-error">*</span> الحقول المُشار إليها إلزامية
          </p>
        </div>
      </form>
    </div>
  </section>
</main>

