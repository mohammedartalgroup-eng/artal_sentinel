    }
    /* ─── Searchable Select ─────────────────────────────────── */
    .ss-trigger {
      background: var(--md-sys-color-surface-container-low, #eff1f4);
      border-radius: 0.5rem;
      transition: box-shadow .15s, background .15s;
      cursor: pointer;
    }
    .ss-trigger:focus { outline: none; box-shadow: 0 0 0 2px rgba(var(--primary-rgb,0,23,54),.2); }
    .ss-trigger:disabled { opacity: .5; cursor: not-allowed; }
    .ss-panel { max-height: 320px; }
    .ss-option { transition: background .1s; }
    .ss-option:hover { background: #f2f4f6; }
    .ss-option.ss-selected { background: rgba(0,23,54,.06); font-weight: 600; color:#001736; }
    /* error state for searchable select */
