<%
  // تواريخ ديناميكية حتى يبقى إعلان الوظيفة "طازجاً" في نتائج Google for Jobs ولا "ينتهي".
  // نفس نمط views/city-jobs.ejs — التقديم متاح دائماً، فلا ينبغي أن ينقضي الإعلان بتاريخ ثابت.
  // datePosted يُثبَّت على أول الشهر الحالي (يتجدّد شهرياً كإعلان "محدّث" طبيعي، لا "اليوم" عند كل زحف).
  // مكوّنات UTC مقصودة: new Date(y,m,1).toISOString() قد يرجع آخر يوم في الشهر السابق بفارق توقيت السعودية.
  const _today = new Date();
  const datePosted   = `${_today.getUTCFullYear()}-${String(_today.getUTCMonth() + 1).padStart(2, '0')}-01`;
  const validThrough = new Date(_today.getTime() + 60 * 86400000).toISOString().split('T')[0];
%><!DOCTYPE html>
