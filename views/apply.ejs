    .err-msg {
      display: none;
      align-items: center;
      gap: 4px;
      color: #dc2626;
      font-size: 0.72rem;
      margin-top: 6px;
      font-weight: 500;
    }
    .err-msg.show { display: flex; }
    .err-msg::before {
      content: '●';
      font-size: 0.5rem;
      flex-shrink: 0;
    }
    /* تحريك الخطأ عند ظهوره */
    @keyframes errIn {
      from { opacity:0; transform: translateY(-4px); }
