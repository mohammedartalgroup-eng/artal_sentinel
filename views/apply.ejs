<body class="text-on-background">

<header class="bg-[#001736] top-0 z-50">
  <div class="flex justify-center items-center py-4 w-full max-w-7xl mx-auto px-6">
    <div class="bg-white rounded-xl px-5 py-2 shadow-lg">
      <img src="/images/icon.png" alt="أرتال للحراسة الأمنية" class="h-12 w-auto object-contain">
    </div>
  </div>
</header>

<main class="min-h-screen">
  <!-- Hero Section -->
  <section class="relative h-[400px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img class="w-full h-full object-cover"
           src="https://lh3.googleusercontent.com/aida-public/AB6AXuAtzVauCXhqadAQOZ35FTSVSaSESW7rwlnFy_9aPJuYKdHQCtTOVmZEymMt2IiI3ZeVUKWBBKrkCD6yiK7QIYMm0lsWSWnQXVcZR26T5AOWAcRfAuVm9vavhWKeGSXcGJI9hYdphDKg3ZMwYLLnIPYRd05tO3-Ce1g-9I1M7WhvpPh9TlKSwXNSPlwJMgHgnZCMHOYRYN3rezbwmaUVNtwMpgchRotftKOemd--te6i0-uKED2vu4dy7t_MjiERbLDaJYq3gssUM93_"
           alt="شركة أرتال للحراسات الأمنية المدنية الخاصة — وظائف حراسة أمنية في السعودية">
      <div class="absolute inset-0 bg-primary/80 backdrop-blur-sm"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
        انضم إلى شركة أرتال للحراسات الأمنية المدنية الخاصة
      </h1>
      <p class="text-on-primary-container font-medium text-lg max-w-2xl mx-auto opacity-90">
        نبحث عن الكفاءات الوطنية المتميزة للانضمام إلى فريقنا الاحترافي في تقديم الحلول الأمنية المتقدمة
      </p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="relative z-20 -mt-24 px-4 pb-20">
    <div class="max-w-3xl mx-auto bg-surface-container-lowest rounded-xl shadow-2xl overflow-hidden border border-outline-variant/10">
      <div class="bg-primary-container p-8 text-white">
        <div class="flex items-center gap-3 mb-2">
          <span class="material-symbols-outlined text-tertiary-fixed">assignment_ind</span>
          <h2 class="text-2xl font-bold">طلب توظيف جديد</h2>
        </div>
        <p class="text-slate-300 text-sm">يرجى تعبئة كافة البيانات المطلوبة بدقة ليتم التواصل معكم</p>
      </div>

      <form class="p-8 md:p-12 space-y-8" method="POST" action="/apply"
            enctype="multipart/form-data" id="applyForm" novalidate>

        <!-- حقول مصدر الزيارة (تُملأ تلقائياً عبر /js/attribution.js) -->
        <input type="hidden" name="source" id="f-source">
        <input type="hidden" name="referrer" id="f-referrer">
        <input type="hidden" name="landing_page" id="f-landing">

        <!-- Personal Info Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <!-- Full Name -->
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-on-surface-variant mb-2">
              الاسم الرباعي <span class="text-error">*</span>
            </label>
            <div class="input-wrap relative" id="wrap-full_name">
              <input id="f-full_name" name="full_name"
                     class="w-full bg-surface-container-low border-0 rounded-lg px-4 py-3.5 focus:ring-2 focus:ring-primary/20 transition-all placeholder:text-slate-400"
                     placeholder="أدخل اسمك الكامل كما في الهوية" type="text" autocomplete="name"/>
              <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-slate-400">person</span>
            </div>
            <p class="err-msg" id="err-full_name">الاسم الرباعي مطلوب (5 أحرف على الأقل)</p>
          </div>

          <!-- ID Number -->
          <div>
            <label class="block text-sm font-semibold text-on-surface-variant mb-2">
              رقم الهوية الوطنية <span class="text-error">*</span>
            </label>
            <div class="input-wrap" id="wrap-id_number">
              <input id="f-id_number" name="id_number"
                     class="w-full bg-surface-container-low border-0 rounded-lg px-4 py-3.5 focus:ring-2 focus:ring-primary/20 transition-all font-mono"
                     placeholder="1XXXXXXXXX"
                     type="text"
                     inputmode="numeric"
                     maxlength="10"
                     dir="ltr"
                     autocomplete="off"/>
            </div>
            <p class="err-msg" id="err-id_number">رقم الهوية يجب أن يكون 10 أرقام إنجليزية</p>
          </div>

          <!-- Mobile Number -->
          <div>
            <label class="block text-sm font-semibold text-on-surface-variant mb-2">
              رقم الجوال <span class="text-error">*</span>
            </label>
            <div class="input-wrap relative" id="wrap-phone">
              <input id="f-phone" name="phone"
                     class="w-full bg-surface-container-low border-0 rounded-lg px-4 py-3.5 focus:ring-2 focus:ring-primary/20 transition-all font-mono"
                     placeholder="05XXXXXXXX"
                     type="tel"
                     inputmode="numeric"
                     maxlength="10"
                     dir="ltr"
                     autocomplete="tel"/>
              <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-slate-400">smartphone</span>
            </div>
            <p class="err-msg" id="err-phone">رقم الجوال يجب أن يبدأ بـ 05 ويتكون من 10 أرقام</p>
          </div>

          <!-- Age -->
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-on-surface-variant mb-2">
              العمر <span class="text-error">*</span>
            </label>
            <div class="input-wrap" id="wrap-age">
              <input id="f-age" name="age" min="23" max="99"
                     class="w-full bg-surface-container-low border-0 rounded-lg px-4 py-3.5 focus:ring-2 focus:ring-primary/20 transition-all"
                     placeholder="السنة (23 فأكبر)" type="number" inputmode="numeric"/>
            </div>
            <p class="err-msg" id="err-age">العمر مطلوب ويجب أن يكون 23 سنة فأكبر</p>
          </div>

          <!-- Region (full width) -->
          <div class="md:col-span-2">
            <label class="block text-sm font-semibold text-on-surface-variant mb-2">
              المنطقة الإدارية <span class="text-error">*</span>
            </label>
            <div class="input-wrap relative" id="wrap-region">
              <input type="hidden" name="region" id="f-region" value="">
              <button type="button" id="ss-region-trigger"
                      class="ss-trigger w-full px-4 py-3.5 flex items-center justify-between gap-2 text-sm"
                      onclick="ssToggle('region')">
                <span id="ss-region-display" class="text-slate-400">اختر المنطقة الإدارية</span>
