<script>
// ─── بيانات المناطق والمدن ────────────────────────────────────────────────────
let SA_DATA = [];
let SS_ACTIVE = null; // الـ panel المفتوح حالياً

fetch('/data/sa-regions.json')
  .then(r => r.json())
  .then(data => {
    SA_DATA = data;
    ssRenderList('region', data.map(r => r.name));
  })
  .catch(() => {
    document.getElementById('ss-region-display').textContent = '— تعذّر التحميل —';
  });

// ─── Searchable Select API ────────────────────────────────────────────────────
function ssRenderList(id, items) {
  const list   = document.getElementById(`ss-${id}-list`);
  const hidden = document.getElementById(`f-${id}`);
  if (!items.length) {
    list.innerHTML = '<li class="px-4 py-3 text-slate-400 text-center text-xs">لا نتائج</li>';
    return;
  }
  list.innerHTML = items.map(item => `
    <li class="ss-option px-4 py-2.5 cursor-pointer flex items-center justify-between
               ${hidden.value === item ? 'ss-selected' : ''}"
        data-value="${item}" onclick="ssSelect('${id}', this.dataset.value)">
      <span>${item}</span>
      ${hidden.value === item ? '<span class="material-symbols-outlined text-[#001736] text-base">check</span>' : ''}
    </li>`).join('');
}

function ssToggle(id) {
  const panel = document.getElementById(`ss-${id}-panel`);
  const isOpen = !panel.classList.contains('hidden');
  if (SS_ACTIVE && SS_ACTIVE !== id) ssClose(SS_ACTIVE);
  isOpen ? ssClose(id) : ssOpen(id);
}

function ssOpen(id) {
  const panel  = document.getElementById(`ss-${id}-panel`);
  const arrow  = document.getElementById(`ss-${id}-arrow`);
  const search = document.getElementById(`ss-${id}-search`);
  panel.classList.remove('hidden');
  arrow.style.transform = 'rotate(180deg)';
  search.value = '';
  ssFilter(id); // reset filter
  search.focus();
  SS_ACTIVE = id;
}

function ssClose(id) {
  const panel = document.getElementById(`ss-${id}-panel`);
  const arrow = document.getElementById(`ss-${id}-arrow`);
  if (panel) panel.classList.add('hidden');
  if (arrow) arrow.style.transform = '';
  if (SS_ACTIVE === id) SS_ACTIVE = null;
}

function ssFilter(id) {
  const q = document.getElementById(`ss-${id}-search`).value.trim();
  let options;
  if (id === 'region') {
    options = SA_DATA.map(r => r.name);
  } else {
    const rVal = document.getElementById('f-region').value;
    const reg  = SA_DATA.find(r => r.name === rVal);
    options = reg ? reg.cities : [];
  }
  ssRenderList(id, q ? options.filter(o => o.includes(q)) : options);
}

function ssSelect(id, value) {
  const hidden  = document.getElementById(`f-${id}`);
  const display = document.getElementById(`ss-${id}-display`);
  hidden.value  = value;
  display.textContent = value;
  display.classList.remove('text-slate-400');
  display.classList.add('text-[#191c1e]');
  ssClose(id);
  clearError(id);

  // ── Cascade: عند اختيار المنطقة → تهيئة قائمة المدن
  if (id === 'region') {
    const reg = SA_DATA.find(r => r.name === value);
    // إعادة تعيين المدينة
    document.getElementById('f-city').value = '';
    const cityDisplay = document.getElementById('ss-city-display');
    cityDisplay.textContent = 'اختر المدينة / المحافظة';
    cityDisplay.classList.add('text-slate-400');
    cityDisplay.classList.remove('text-[#191c1e]');
    clearError('city');
    // تفعيل قائمة المدن
    const trigger = document.getElementById('ss-city-trigger');
    trigger.disabled = false;
    if (reg) ssRenderList('city', reg.cities);
  }
}

// ── إغلاق عند الضغط خارج أي dropdown
document.addEventListener('click', e => {
  if (!SS_ACTIVE) return;
  const wrap = document.getElementById(`wrap-${SS_ACTIVE}`);
  if (wrap && !wrap.contains(e.target)) ssClose(SS_ACTIVE);
});

// ─── تحويل الأرقام العربية والفارسية إلى إنجليزية ───────────────────────────
function toEnglish(str) {
  return str
    .replace(/[\u0660-\u0669]/g, d => d.charCodeAt(0) - 0x0660) // عربي ٠-٩
    .replace(/[\u06F0-\u06F9]/g, d => d.charCodeAt(0) - 0x06F0); // فارسي ۰-۹
}

// ─── إعداد حقل رقمي إنجليزي فقط ────────────────────────────────────────────
function setupNumericOnly(inputId) {
  const el = document.getElementById(inputId);
  if (!el) return;

  el.addEventListener('input', function () {
    // حوّل أي أرقام عربية ثم احذف كل ما ليس رقماً إنجليزياً
    const cleaned = toEnglish(this.value).replace(/\D/g, '');
    if (this.value !== cleaned) {
      // احتفظ بموقع المؤشر
      const pos = this.selectionStart - (this.value.length - cleaned.length);
      this.value = cleaned;
      try { this.setSelectionRange(pos, pos); } catch(e) {}
    }
    clearError(inputId.replace('f-', ''));
  });

  // لصق النص — نفس التحويل
  el.addEventListener('paste', function (e) {
    e.preventDefault();
    const pasted = (e.clipboardData || window.clipboardData).getData('text');
    const cleaned = toEnglish(pasted).replace(/\D/g, '');
    const start = this.selectionStart, end = this.selectionEnd;
    this.value = this.value.slice(0, start) + cleaned + this.value.slice(end);
    this.value = this.value.slice(0, parseInt(this.maxLength) || 999);
    clearError(inputId.replace('f-', ''));
  });
}

// ─── إظهار خطأ ──────────────────────────────────────────────────────────────
function showError(fieldName, msg) {
  const wrap = document.getElementById('wrap-' + fieldName);
  const err  = document.getElementById('err-' + fieldName);
  if (wrap) wrap.classList.add('has-error');
  if (err)  { if (msg) err.textContent = msg; err.classList.add('show'); }
}

// ─── مسح خطأ ────────────────────────────────────────────────────────────────
function clearError(fieldName) {
  const wrap = document.getElementById('wrap-' + fieldName);
  const err  = document.getElementById('err-' + fieldName);
  if (wrap) wrap.classList.remove('has-error');
  if (err)  err.classList.remove('show');
}

// ─── مسح الخطأ عند الكتابة في الحقول النصية ────────────────────────────────
['full_name', 'age'].forEach(name => {
  const el = document.getElementById('f-' + name);
  if (el) el.addEventListener('input', () => clearError(name));
});
// clearError للمنطقة والمدينة يتم داخل ssSelect مباشرةً
document.getElementById('f-neighborhood')?.addEventListener('input', () => clearError('neighborhood'));

// ─── إعداد حقلي الهوية والجوال ──────────────────────────────────────────────
setupNumericOnly('f-id_number');
setupNumericOnly('f-phone');

// ─── إصلاح: إعادة تعيين زر الإرسال إذا استُعيدت الصفحة من ذاكرة المتصفح (زر الرجوع)
//     (كان الزر يبقى "يدور/معطّلاً" بعد الرجوع من صفحة نتيجة الإرسال)
(function () {
  var _btn = document.getElementById('submitBtn');
  var _orig = _btn ? _btn.innerHTML : '';
  window.addEventListener('pageshow', function (e) {
    if (e.persisted && _btn) { _btn.disabled = false; _btn.innerHTML = _orig; }
  });
})();

// ─── التحقق عند الإرسال ─────────────────────────────────────────────────────
document.getElementById('applyForm').addEventListener('submit', function (e) {
  e.preventDefault(); // نمنع الإرسال حتى نتحقق

  let valid = true;
  let firstError = null;

  // ── الاسم الرباعي
  const name = document.getElementById('f-full_name').value.trim();
  if (name.length < 5) {
    showError('full_name', 'الاسم الرباعي مطلوب (5 أحرف على الأقل)');
    if (!firstError) firstError = 'f-full_name';
    valid = false;
  } else {
    clearError('full_name');
  }

  // ── رقم الهوية: 10 أرقام إنجليزية بالضبط
  const idVal = document.getElementById('f-id_number').value;
  if (!/^\d{10}$/.test(idVal)) {
    showError('id_number', 'رقم الهوية يجب أن يكون 10 أرقام إنجليزية بالضبط');
    if (!firstError) firstError = 'f-id_number';
    valid = false;
  } else {
    clearError('id_number');
  }

  // ── رقم الجوال: يبدأ بـ 05 وطوله 10
  const phone = document.getElementById('f-phone').value;
  if (!/^05\d{8}$/.test(phone)) {
    showError('phone', 'رقم الجوال يجب أن يبدأ بـ 05 ويتكون من 10 أرقام إنجليزية');
    if (!firstError) firstError = 'f-phone';
    valid = false;
  } else {
    clearError('phone');
  }

  // ── العمر (إلزامي، أكبر من 22)
  const ageVal = document.getElementById('f-age').value;
  const ageNum = parseInt(ageVal);
  if (!ageVal || isNaN(ageNum)) {
    showError('age', 'يرجى إدخال العمر');
    if (!firstError) firstError = 'f-age';
    valid = false;
  } else if (ageNum >= 100) {
    showError('age', 'العمر غير صحيح — يرجى إدخال عمرك وليس سنة ميلادك');
    if (!firstError) firstError = 'f-age';
    valid = false;
  } else if (ageNum <= 22) {
    showError('age', 'العمر يجب أن يكون 23 سنة فأكبر');
    if (!firstError) firstError = 'f-age';
    valid = false;
  } else {
    clearError('age');
  }

  // ── المنطقة الإدارية
  const region = document.getElementById('f-region').value;
  if (!region) {
    showError('region', 'يرجى اختيار المنطقة الإدارية');
    if (!firstError) firstError = 'wrap-region';
    valid = false;
  } else {
    clearError('region');
  }

  // ── المدينة / المحافظة
  const city = document.getElementById('f-city').value;
  if (!city) {
    showError('city', 'يرجى اختيار المدينة أو المحافظة');
    if (!firstError) firstError = 'wrap-city';
    valid = false;
  } else {
    clearError('city');
  }

  // ── الحي (إلزامي)
  const neighborhood = document.getElementById('f-neighborhood').value.trim();
  if (!neighborhood) {
    showError('neighborhood', 'يرجى كتابة اسم الحي');
    if (!firstError) firstError = 'f-neighborhood';
    valid = false;
  } else {
    clearError('neighborhood');
  }

  // ── اللغة الإنجليزية (إلزامي)
  if (!document.querySelector('input[name="english"]:checked')) {
    showError('english', 'يرجى تحديد إجادة اللغة الإنجليزية');
    if (!firstError) firstError = 'wrap-english';
    valid = false;
  } else {
    clearError('english');
  }

  // ── المؤهل (إلزامي)
  if (!document.getElementById('f-qualification').value) {
    showError('qualification', 'يرجى اختيار المؤهل العلمي');
    if (!firstError) firstError = 'wrap-qualification';
    valid = false;
  } else {
    clearError('qualification');
  }

  // ── الجنس (إلزامي)
  if (!document.querySelector('input[name="gender"]:checked')) {
    showError('gender', 'يرجى تحديد الجنس');
    if (!firstError) firstError = 'wrap-gender';
    valid = false;
  } else {
    clearError('gender');
  }

  // ── السيارة (إلزامي)
  if (!document.querySelector('input[name="has_car"]:checked')) {
    showError('has_car', 'يرجى تحديد ما إذا كنت تمتلك سيارة');
    if (!firstError) firstError = 'wrap-has_car';
    valid = false;
  } else {
    clearError('has_car');
  }

  // ── الرخصة (إلزامي)
  if (!document.querySelector('input[name="has_license"]:checked')) {
    showError('has_license', 'يرجى تحديد ما إذا كان لديك رخصة قيادة');
    if (!firstError) firstError = 'wrap-has_license';
    valid = false;
  } else {
    clearError('has_license');
  }

  // ── إذا في أخطاء: اسكرول لأول خطأ
  if (!valid) {
    const errEl = document.getElementById(firstError);
    if (errEl) {
      errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      try { errEl.focus(); } catch(e) {}
    }
    return;
  }

  // ── كل شيء صحيح: أرسل الفورم
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="material-symbols-outlined" style="animation:spin 1s linear infinite">refresh</span> جارٍ الإرسال...';
  this.submit();
});

// ─── تحديث اسم الملف المرفق ──────────────────────────────────────────────────
function updateFileName(input, labelId) {
  const label = document.getElementById(labelId);
  if (input.files && input.files[0]) {
    label.textContent = '✓ ' + input.files[0].name;
    label.style.color = '#15803d';
    label.style.fontWeight = '600';
  }
}

// أنيميشن دوران زر الإرسال
const style = document.createElement('style');
style.textContent = '@keyframes spin { to { transform: rotate(360deg); } }';
document.head.appendChild(style);
</script>
