<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= applicant.full_name %> — أرتال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f2f4f6; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .star-btn { cursor: pointer; font-size: 1.5rem; transition: color 0.15s; }
    .star-btn.active { color: #e2c382; }
    .star-btn:not(.active) { color: #c4c6d0; }
    .star-btn:hover, .star-btn:hover ~ .star-btn { color: #e2c382; }

    /* ─── Print ──────────────────────────────────────── */
    #print-doc { display: none; }
    @media print {
      body > *                { display: none !important; }
      #print-doc              { display: block !important; }
      @page                   { size: A4; margin: 15mm 18mm; }

      /* reset */
      * { -webkit-print-color-adjust: exact; print-color-adjust: exact; }

      .pd-page-break          { page-break-before: always; }
      .pd-avoid-break         { page-break-inside: avoid; }
    }
  </style>
</head>
<body class="text-[#191c1e]">
<%- include('partials/sidebar', { currentPage: 'applicants' }) %>

<%
const colorMap = {
  blue:'bg-blue-100 text-blue-700', yellow:'bg-yellow-100 text-yellow-800',
  purple:'bg-purple-100 text-purple-700', orange:'bg-orange-100 text-orange-700',
  green:'bg-green-100 text-green-700', gray:'bg-gray-100 text-gray-600',
  red:'bg-red-100 text-red-700'
};
const sm = STATUS_META[applicant.status] || { label: applicant.status, color: 'gray' };
%>

<div class="mr-64 min-h-screen">
  <!-- Top bar -->
  <header class="bg-white border-b border-[#eceef0] px-8 py-4 flex items-center gap-4 sticky top-0 z-30">
    <a href="/admin/applicants" class="text-[#43474f] hover:text-[#001736] transition-colors">
      <span class="material-symbols-outlined">arrow_forward</span>
    </a>
    <div class="flex-1">
      <div class="flex items-center gap-3 flex-wrap">
        <h1 class="text-lg font-bold text-[#001736]"><%= applicant.full_name %></h1>
        <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= colorMap[sm.color] %>">
          <%= sm.label %>
        </span>
        <!-- Star rating display -->
        <div class="flex items-center gap-0.5" id="ratingDisplay">
          <% for (let i = 1; i <= 5; i++) { %>
          <button class="star-btn <%= i <= applicant.rating ? 'active' : '' %>"
                  data-value="<%= i %>" onclick="setRating(<%= i %>)" title="<%= i %> نجوم">★</button>
          <% } %>
        </div>
      </div>
      <p class="text-xs text-[#43474f] mt-0.5">
        تقديم رقم #<%= applicant.id %> —
        <%= new Date(applicant.created_at).toLocaleDateString('ar-SA', { year:'numeric', month:'long', day:'numeric' }) %>
      </p>
    </div>
    <div class="flex items-center gap-2">
      <!-- Print button -->
      <button onclick="window.print()"
              class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[#405f91] bg-[#f2f4f6] hover:bg-[#e8ecf4] text-sm font-medium transition-colors">
        <span class="material-symbols-outlined text-base">print</span>
        طباعة
      </button>
      <!-- Delete button — للمديرين فقط -->
      <% if (locals.adminRole === 'manager') { %>
      <button onclick="deleteApplicant()"
              class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-red-600 bg-red-50 hover:bg-red-100 text-sm font-medium transition-colors">
        <span class="material-symbols-outlined text-base">delete</span>
        حذف
      </button>
      <% } %>
    </div>
  </header>

  <!-- Status Pipeline -->
  <div class="bg-white border-b border-[#eceef0] px-8 py-4">
    <div class="flex items-center gap-2 flex-wrap">
      <% const pipeline = ['pending','reviewed','shortlisted','interviewed','hired']; %>
      <% const pipelinePos = pipeline.indexOf(applicant.status); %>
      <% pipeline.forEach((step, i) => { %>
      <%
        let btnClass = 'border border-[#e0e3e5] text-[#43474f] bg-white hover:bg-[#f2f4f6]';
        if (step === applicant.status) btnClass = 'bg-[#001736] text-white border-[#001736]';
        else if (i < pipelinePos) btnClass = 'bg-[#f2f4f6] text-[#43474f] border-[#e0e3e5]';
      %>
      <button onclick="updateStatus('<%= step %>')"
              class="px-4 py-2 rounded-xl text-xs font-semibold transition-all <%= btnClass %>">
        <%= STATUS_META[step].label %>
      </button>
      <% if (i < pipeline.length - 1) { %>
      <span class="text-[#c4c6d0] material-symbols-outlined text-sm">chevron_left</span>
      <% } %>
      <% }) %>
      <span class="mx-2 text-[#c4c6d0]">|</span>
      <button onclick="updateStatus('on_hold')"
              class="px-4 py-2 rounded-xl text-xs font-semibold border transition-all
                     <%= applicant.status === 'on_hold' ? 'bg-gray-500 text-white border-gray-500' : 'border-[#e0e3e5] text-[#43474f] hover:bg-[#f2f4f6]' %>">
        معلق
      </button>
      <button onclick="updateStatus('rejected')"
              class="px-4 py-2 rounded-xl text-xs font-semibold border transition-all
                     <%= applicant.status === 'rejected' ? 'bg-red-600 text-white border-red-600' : 'border-[#e0e3e5] text-red-600 hover:bg-red-50' %>">
        مرفوض
      </button>
    </div>
  </div>

  <main class="p-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- LEFT: Info + Docs -->
      <div class="lg:col-span-1 space-y-6">

        <!-- Personal Info -->
        <div class="bg-white rounded-2xl p-6">
          <h2 class="font-bold text-[#001736] text-sm mb-5 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">assignment_ind</span>
            البيانات الشخصية
          </h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#43474f] text-lg mt-0.5">person</span>
              <div>
                <div class="text-xs text-[#43474f] font-semibold uppercase tracking-wider">الاسم الرباعي</div>
                <div class="font-medium mt-0.5"><%= applicant.full_name %></div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#43474f] text-lg mt-0.5">badge</span>
              <div>
                <div class="text-xs text-[#43474f] font-semibold uppercase tracking-wider">رقم الهوية</div>
                <div class="font-mono mt-0.5"><%= applicant.id_number %></div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#43474f] text-lg mt-0.5">smartphone</span>
              <div>
                <div class="text-xs text-[#43474f] font-semibold uppercase tracking-wider">رقم الجوال</div>
                <div class="mt-0.5" dir="ltr"><%= applicant.phone %></div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#43474f] text-lg mt-0.5">cake</span>
              <div>
                <div class="text-xs text-[#43474f] font-semibold uppercase tracking-wider">العمر</div>
                <div class="mt-0.5"><%= applicant.age ? applicant.age + ' سنة' : '—' %></div>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="material-symbols-outlined text-[#43474f] text-lg mt-0.5">location_on</span>
              <div>
                <div class="text-xs text-[#43474f] font-semibold uppercase tracking-wider">مقر السكن</div>
                <% if (applicant.region) { %>
                <div class="text-xs text-[#7594ca] font-medium mt-0.5"><%= applicant.region %></div>
                <% } %>
                <div class="mt-0.5"><%= applicant.city || '—' %></div>
                <% if (applicant.neighborhood) { %>
                <div class="text-xs text-[#43474f] mt-0.5">حي <%= applicant.neighborhood %></div>
                <% } %>
              </div>
            </div>
            <%
              const QUAL_LABELS = { none:'بدون مؤهل', primary:'ابتدائي', middle:'متوسط', high_school:'ثانوي', university:'جامعي' };
            %>
            <% if (applicant.qualification) { %>
            <div class="flex items-start gap-3 pt-1">
              <span class="material-symbols-outlined text-[#43474f] text-lg mt-0.5">school</span>
              <div>
                <div class="text-xs text-[#43474f] font-semibold uppercase tracking-wider">المؤهل العلمي</div>
                <div class="mt-0.5 font-medium"><%= QUAL_LABELS[applicant.qualification] || applicant.qualification %></div>
                <% if (applicant.specialization) { %>
                <div class="text-xs text-[#7594ca] mt-0.5">تخصص: <%= applicant.specialization %></div>
                <% } %>
              </div>
            </div>
            <% } %>

            <div class="grid grid-cols-2 gap-3 pt-2">
              <div class="bg-[#f8f9fb] rounded-xl p-3 text-center">
                <span class="material-symbols-outlined text-2xl <%= applicant.gender === 'male' ? 'text-blue-500' : applicant.gender === 'female' ? 'text-pink-500' : 'text-[#c4c6d0]' %>">
                  <%= applicant.gender === 'female' ? 'female' : 'male' %>
                </span>
                <div class="text-xs text-[#43474f] mt-1">الجنس</div>
                <div class="text-sm font-semibold <%= applicant.gender === 'male' ? 'text-blue-600' : applicant.gender === 'female' ? 'text-pink-600' : 'text-[#43474f]' %>">
                  <%= applicant.gender === 'male' ? 'ذكر' : applicant.gender === 'female' ? 'أنثى' : '—' %>
                </div>
              </div>
              <div class="bg-[#f8f9fb] rounded-xl p-3 text-center">
                <span class="material-symbols-outlined text-2xl <%= applicant.has_car ? 'text-green-600' : 'text-[#c4c6d0]' %>">
                  directions_car
                </span>
                <div class="text-xs text-[#43474f] mt-1">سيارة</div>
                <div class="text-sm font-semibold <%= applicant.has_car ? 'text-green-700' : 'text-[#43474f]' %>">
                  <%= applicant.has_car ? 'نعم' : 'لا' %>
                </div>
              </div>
              <div class="bg-[#f8f9fb] rounded-xl p-3 text-center">
                <span class="material-symbols-outlined text-2xl <%= applicant.has_license ? 'text-green-600' : 'text-[#c4c6d0]' %>">
                  card_membership
                </span>
                <div class="text-xs text-[#43474f] mt-1">رخصة</div>
                <div class="text-sm font-semibold <%= applicant.has_license ? 'text-green-700' : 'text-[#43474f]' %>">
                  <%= applicant.has_license ? 'نعم' : 'لا' %>
                </div>
              </div>
              <% if (applicant.english != null) { %>
              <div class="bg-[#f8f9fb] rounded-xl p-3 text-center">
                <span class="material-symbols-outlined text-2xl <%= applicant.english ? 'text-blue-500' : 'text-[#c4c6d0]' %>">
                  translate
                </span>
                <div class="text-xs text-[#43474f] mt-1">إنجليزية</div>
                <div class="text-sm font-semibold <%= applicant.english ? 'text-blue-600' : 'text-[#43474f]' %>">
                  <%= applicant.english ? 'نعم' : 'لا' %>
                </div>
              </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Documents -->
        <div class="bg-white rounded-2xl p-6">
          <h2 class="font-bold text-[#001736] text-sm mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">folder_open</span>
            المرفقات
          </h2>
          <div class="space-y-3">
            <% if (applicant.cv_path) { %>
            <a href="/uploads/cv/<%= applicant.cv_path %>" target="_blank"
               class="flex items-center gap-3 p-3 bg-[#f8f9fb] rounded-xl hover:bg-[#f2f4f6] transition-colors group">
              <div class="w-10 h-10 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-red-600 text-lg">description</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-[#001736] truncate">السيرة الذاتية</div>
                <div class="text-xs text-[#43474f]">CV</div>
              </div>
              <span class="material-symbols-outlined text-[#405f91] text-lg group-hover:scale-110 transition-transform">
                open_in_new
              </span>
            </a>
            <% } else { %>
            <div class="flex items-center gap-3 p-3 bg-[#f8f9fb] rounded-xl opacity-50">
              <div class="w-10 h-10 rounded-lg bg-[#eceef0] flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-[#c4c6d0] text-lg">description</span>
              </div>
              <div class="text-sm text-[#43474f]">لم يرفع السيرة الذاتية</div>
            </div>
            <% } %>

            <% if (applicant.id_image_path) { %>
            <a href="/uploads/id_images/<%= applicant.id_image_path %>" target="_blank"
               class="flex items-center gap-3 p-3 bg-[#f8f9fb] rounded-xl hover:bg-[#f2f4f6] transition-colors group">
              <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-blue-600 text-lg">badge</span>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-medium text-[#001736]">صورة الهوية</div>
                <div class="text-xs text-[#43474f]">ID Image</div>
              </div>
              <span class="material-symbols-outlined text-[#405f91] text-lg group-hover:scale-110 transition-transform">
                open_in_new
              </span>
            </a>
            <% } else { %>
            <div class="flex items-center gap-3 p-3 bg-[#f8f9fb] rounded-xl opacity-50">
              <div class="w-10 h-10 rounded-lg bg-[#eceef0] flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-[#c4c6d0] text-lg">badge</span>
              </div>
              <div class="text-sm text-[#43474f]">لم يرفع صورة الهوية</div>
            </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- RIGHT: CRM Timeline + Notes -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Add Note -->
        <div class="bg-white rounded-2xl p-6">
          <h2 class="font-bold text-[#001736] text-sm mb-4 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">add_comment</span>
            إضافة ملاحظة / نشاط
          </h2>
          <div id="noteForm" class="space-y-3">
            <div class="flex gap-3 flex-wrap">
              <% Object.entries(NOTE_TYPES).forEach(([k, v]) => { %>
              <label class="flex items-center gap-2 cursor-pointer group">
                <input type="radio" name="note_type_select" value="<%= k %>" class="hidden"
                       onchange="selectNoteType('<%= k %>')" <%= k === 'note' ? 'checked' : '' %>>
                <div class="note-type-btn px-3 py-1.5 rounded-xl border text-xs font-semibold transition-all cursor-pointer flex items-center gap-1.5
                            <%= k === 'note' ? 'bg-[#001736] text-white border-[#001736]' : 'border-[#e0e3e5] text-[#43474f] hover:bg-[#f2f4f6]' %>"
                     data-type="<%= k %>">
                  <span class="material-symbols-outlined text-sm"><%= v.icon %></span>
                  <%= v.label %>
                </div>
              </label>
              <% }) %>
            </div>
            <textarea id="noteContent" rows="3" placeholder="اكتب ملاحظتك هنا..."
                      class="w-full border border-[#e0e3e5] rounded-xl p-3 text-sm focus:outline-none focus:border-[#7594ca] focus:ring-1 focus:ring-[#7594ca]/30 resize-none transition-all"
                      onkeydown="if(event.ctrlKey && event.key==='Enter') addNote()"></textarea>
            <div class="flex items-center justify-between">
              <span class="text-xs text-[#43474f]">Ctrl+Enter للإضافة السريعة</span>
              <button onclick="addNote()"
                      class="bg-[#001736] text-white text-sm font-semibold px-5 py-2.5 rounded-xl hover:bg-[#002b5b] transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-base">send</span>
                إضافة
              </button>
            </div>
          </div>
        </div>

        <!-- Timeline -->
        <div class="bg-white rounded-2xl p-6">
          <h2 class="font-bold text-[#001736] text-sm mb-5 flex items-center gap-2">
            <span class="material-symbols-outlined text-base">timeline</span>
            السجل والملاحظات
          </h2>

          <div id="timeline" class="space-y-0">
            <%
            const noteTypeColors = {
              note: 'bg-blue-100 text-blue-700',
              call: 'bg-green-100 text-green-700',
              interview: 'bg-purple-100 text-purple-700',
              follow_up: 'bg-orange-100 text-orange-700'
            };
            // Merge notes + activity into one timeline, sorted by date desc
            const timelineItems = [
              ...notes.map(n => ({ ...n, _type: 'note' })),
              ...activity.map(a => ({ ...a, _type: 'activity' }))
            ].sort((a, b) => new Date(b.created_at) - new Date(a.created_at));
            %>

            <% if (timelineItems.length === 0) { %>
            <div class="text-center py-8 text-[#43474f] text-sm">
              <span class="material-symbols-outlined text-3xl block mb-2 text-[#c4c6d0]">chat_bubble_outline</span>
              لا توجد ملاحظات أو سجل نشاط بعد
            </div>
            <% } %>

            <% timelineItems.forEach((item, idx) => { %>
            <div class="flex gap-4 pb-5 <%= idx < timelineItems.length - 1 ? 'border-b border-[#f2f4f6]' : '' %>"
                 id="<%= item._type === 'note' ? 'note-' + item.id : '' %>">
              <!-- Icon -->
              <div class="flex-shrink-0 mt-1">
                <% if (item._type === 'note') { %>
                <div class="w-9 h-9 rounded-xl <%= noteTypeColors[item.type] || 'bg-gray-100 text-gray-600' %> flex items-center justify-center">
                  <span class="material-symbols-outlined text-base"><%= NOTE_TYPES[item.type]?.icon || 'edit_note' %></span>
                </div>
                <% } else { %>
                <div class="w-9 h-9 rounded-xl bg-[#f2f4f6] flex items-center justify-center">
                  <span class="material-symbols-outlined text-base text-[#43474f]">history</span>
                </div>
                <% } %>
              </div>
              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                  <div class="flex-1">
                    <% if (item._type === 'note') { %>
                    <span class="text-xs font-semibold <%= noteTypeColors[item.type] || 'bg-gray-100 text-gray-600' %> px-2 py-0.5 rounded-full">
                      <%= NOTE_TYPES[item.type]?.label || item.type %>
                    </span>
                    <p class="text-sm text-[#191c1e] mt-2 leading-relaxed"><%= item.content %></p>
                    <% } else { %>
                    <div class="text-sm text-[#43474f]">
                      <span class="font-medium text-[#191c1e]"><%= item.action %></span>
                      <% if (item.old_value && item.new_value) { %>
                      <span class="mx-1">:</span>
                      <span class="line-through text-[#c4c6d0]"><%= item.old_value %></span>
                      <span class="mx-1 material-symbols-outlined text-xs align-middle">arrow_back</span>
                      <span class="font-medium text-[#001736]"><%= item.new_value %></span>
                      <% } else if (item.new_value) { %>
                      <span class="mx-1">—</span><span class="text-[#001736]"><%= item.new_value %></span>
                      <% } %>
                    </div>
                    <% } %>
                  </div>
                  <div class="flex items-center gap-2 flex-shrink-0">
                    <div class="text-left">
                      <% if (item.user_name) { %>
                      <span class="block text-[10px] text-[#7594ca] font-medium whitespace-nowrap">
                        <span class="material-symbols-outlined text-[10px] align-middle" style="font-variation-settings:'FILL' 1">person</span>
                        <%= item.user_name %>
                      </span>
                      <% } %>
                      <span class="text-xs text-[#43474f] whitespace-nowrap">
                        <%= new Date(item.created_at).toLocaleDateString('ar-SA') %>
                        <%= new Date(item.created_at).toLocaleTimeString('ar-SA', { hour: '2-digit', minute: '2-digit' }) %>
                      </span>
                    </div>
                    <% if (item._type === 'note' && locals.adminRole === 'manager') { %>
                    <button onclick="deleteNote(<%= item.id %>)"
                            class="text-[#c4c6d0] hover:text-red-500 transition-colors" title="حذف">
                      <span class="material-symbols-outlined text-sm">close</span>
                    </button>
                    <% } %>
                  </div>
                </div>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

      </div>
    </div>
  </main>
</div>

<!-- ═══════════════════════════════════════════════════════════
     صفحة الطباعة — تظهر فقط عند print
     ═══════════════════════════════════════════════════════════ -->
<div id="print-doc" dir="rtl" lang="ar"
     style="font-family:'Segoe UI',Tahoma,Arial,sans-serif;color:#111;background:#fff;max-width:100%">

  <%
    const printDate = new Date().toLocaleDateString('ar-SA', { year:'numeric', month:'long', day:'numeric' });
    const printTime = new Date().toLocaleTimeString('ar-SA', { hour:'2-digit', minute:'2-digit' });
    const appliedDate = new Date(applicant.created_at).toLocaleDateString('ar-SA', { year:'numeric', month:'long', day:'numeric' });
    const genderLabel = applicant.gender === 'male' ? 'ذكر' : applicant.gender === 'female' ? 'أنثى' : '—';
    const statusLabel = STATUS_META[applicant.status]?.label || applicant.status;
    const ratingStars = '★'.repeat(applicant.rating) + '☆'.repeat(5 - applicant.rating);
    const QUAL_PRINT = { none:'بدون مؤهل', primary:'ابتدائي', middle:'متوسط', high_school:'ثانوي', university:'جامعي' };
    // الطباعة: الملاحظات + سجل النظام معاً، مرتّبة من الأقدم للأحدث
    const printTimeline = [
      ...notes.map(n => ({ ...n, _type: 'note' })),
      ...activity.map(a => ({ ...a, _type: 'activity' }))
    ].sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
  %>

  <!-- ── رأس الصفحة ─────────────────────────────────────────── -->
  <div style="border-bottom:3px solid #001736;padding-bottom:14px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between">
    <div style="display:flex;align-items:center;gap:14px">
      <img src="/images/icon.png" alt="أرتال" style="height:52px;width:auto;object-fit:contain">
      <div>
        <div style="font-size:18px;font-weight:800;color:#001736">شركة أرتال للحراسات الأمنية المدنية الخاصة</div>
        <div style="font-size:11px;color:#506169;margin-top:2px;letter-spacing:0.04em">نموذج طلب توظيف — ملف متقدم</div>
      </div>
    </div>
    <div style="text-align:left;font-size:11px;color:#506169;line-height:1.7">
      <div><strong style="color:#001736">رقم الملف:</strong> #<%= applicant.id %></div>
      <div><strong style="color:#001736">طُبع بتاريخ:</strong> <%= printDate %> الساعة <%= printTime %></div>
    </div>
  </div>

  <!-- ── البيانات الشخصية ───────────────────────────────────── -->
  <div class="pd-avoid-break" style="margin-bottom:20px">
    <div style="background:#001736;color:#fff;padding:7px 12px;border-radius:6px;font-size:12px;font-weight:700;margin-bottom:10px">
      البيانات الشخصية
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:13px">
      <tbody>
        <tr style="background:#f8f9fb">
          <td style="padding:8px 12px;font-weight:700;color:#43474f;width:28%;border:1px solid #e0e3e5">الاسم الرباعي</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5;font-weight:600;font-size:14px"><%= applicant.full_name %></td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;width:28%;border:1px solid #e0e3e5">رقم الهوية الوطنية</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5;font-family:monospace;direction:ltr;text-align:right"><%= applicant.id_number %></td>
        </tr>
        <tr>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">رقم الجوال</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5;direction:ltr;text-align:right"><%= applicant.phone %></td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">العمر</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5"><%= applicant.age ? applicant.age + ' سنة' : '—' %></td>
        </tr>
        <tr style="background:#f8f9fb">
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">الجنس</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5"><%= genderLabel %></td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">المنطقة الإدارية</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5"><%= applicant.region || '—' %></td>
        </tr>
        <tr>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">المدينة / المحافظة</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5"><%= applicant.city || '—' %></td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">الحي</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5"><%= applicant.neighborhood || '—' %></td>
        </tr>
        <tr style="background:#f8f9fb">
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">يمتلك سيارة</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5">
            <span style="color:<%= applicant.has_car ? '#15803d' : '#6b7280' %>;font-weight:600">
              <%= applicant.has_car ? '✓ نعم' : '✗ لا' %>
            </span>
          </td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">رخصة قيادة</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5">
            <span style="color:<%= applicant.has_license ? '#15803d' : '#6b7280' %>;font-weight:600">
              <%= applicant.has_license ? '✓ نعم' : '✗ لا' %>
            </span>
          </td>
        </tr>
        <tr>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">إجادة الإنجليزية</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5">
            <% if (applicant.english == null) { %>—<% } else { %>
            <span style="color:<%= applicant.english ? '#15803d' : '#6b7280' %>;font-weight:600">
              <%= applicant.english ? '✓ نعم' : '✗ لا' %>
            </span>
            <% } %>
          </td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">المؤهل العلمي</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5">
            <%= QUAL_PRINT[applicant.qualification] || applicant.qualification || '—' %>
            <% if (applicant.specialization) { %>
            <span style="color:#506169;font-size:11px"> · تخصص: <%= applicant.specialization %></span>
            <% } %>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ── حالة الطلب ─────────────────────────────────────────── -->
  <div class="pd-avoid-break" style="margin-bottom:20px">
    <div style="background:#001736;color:#fff;padding:7px 12px;border-radius:6px;font-size:12px;font-weight:700;margin-bottom:10px">
      حالة الطلب
    </div>
    <table style="width:100%;border-collapse:collapse;font-size:13px">
      <tbody>
        <tr style="background:#f8f9fb">
          <td style="padding:8px 12px;font-weight:700;color:#43474f;width:28%;border:1px solid #e0e3e5">تاريخ التقديم</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5"><%= appliedDate %></td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;width:28%;border:1px solid #e0e3e5">الحالة الحالية</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5;font-weight:700"><%= statusLabel %></td>
        </tr>
        <tr>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">التقييم</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5;font-size:16px;letter-spacing:2px"><%= ratingStars %> (<%= applicant.rating %>/5)</td>
          <td style="padding:8px 12px;font-weight:700;color:#43474f;border:1px solid #e0e3e5">المرفقات</td>
          <td style="padding:8px 12px;border:1px solid #e0e3e5">
            <span style="color:<%= applicant.cv_path ? '#15803d' : '#6b7280' %>"><%= applicant.cv_path ? '✓' : '✗' %> السيرة الذاتية</span>
            &nbsp;&nbsp;
            <span style="color:<%= applicant.id_image_path ? '#15803d' : '#6b7280' %>"><%= applicant.id_image_path ? '✓' : '✗' %> صورة الهوية</span>
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- ── السجل والملاحظات ───────────────────────────────────── -->
  <div style="margin-bottom:20px">
    <div style="background:#001736;color:#fff;padding:7px 12px;border-radius:6px;font-size:12px;font-weight:700;margin-bottom:10px">
      السجل الكامل والملاحظات
      <span style="font-weight:400;font-size:11px;opacity:0.7;margin-right:8px">(<%= printTimeline.length %> إدخال، مرتّب من الأقدم للأحدث)</span>
    </div>

    <% if (printTimeline.length === 0) { %>
    <div style="text-align:center;padding:20px;color:#6b7280;font-size:13px;border:1px dashed #e0e3e5;border-radius:6px">
      لا يوجد سجل أو ملاحظات بعد
    </div>
    <% } else { %>
    <table style="width:100%;border-collapse:collapse;font-size:12px">
      <thead>
        <tr style="background:#f2f4f6">
          <th style="padding:8px 10px;text-align:right;font-weight:700;color:#43474f;border:1px solid #e0e3e5;width:13%">التاريخ والوقت</th>
          <th style="padding:8px 10px;text-align:right;font-weight:700;color:#43474f;border:1px solid #e0e3e5;width:12%">النوع</th>
          <th style="padding:8px 10px;text-align:right;font-weight:700;color:#43474f;border:1px solid #e0e3e5;width:14%">بواسطة</th>
          <th style="padding:8px 10px;text-align:right;font-weight:700;color:#43474f;border:1px solid #e0e3e5">التفاصيل</th>
        </tr>
      </thead>
      <tbody>
        <% printTimeline.forEach((item, idx) => { %>
        <tr class="pd-avoid-break" style="background:<%= idx % 2 === 0 ? '#fff' : '#fafbfc' %>">
          <td style="padding:8px 10px;border:1px solid #e0e3e5;color:#506169;white-space:nowrap;font-size:11px">
            <%= new Date(item.created_at).toLocaleDateString('ar-SA') %><br>
            <span style="color:#7594ca"><%= new Date(item.created_at).toLocaleTimeString('ar-SA', { hour:'2-digit', minute:'2-digit' }) %></span>
          </td>
          <td style="padding:8px 10px;border:1px solid #e0e3e5;text-align:center">
            <% if (item._type === 'note') { %>
            <span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;
              background:<%= item.type==='call'?'#dcfce7':item.type==='interview'?'#ede9fe':item.type==='follow_up'?'#ffedd5':'#dbeafe' %>;
              color:<%= item.type==='call'?'#15803d':item.type==='interview'?'#7c3aed':item.type==='follow_up'?'#c2410c':'#1d4ed8' %>">
              <%= NOTE_TYPES[item.type]?.label || item.type %>
            </span>
            <% } else { %>
            <span style="font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;background:#f2f4f6;color:#43474f">
              سجل النظام
            </span>
            <% } %>
          </td>
          <td style="padding:8px 10px;border:1px solid #e0e3e5;color:#506169;font-size:11px">
            <%= item.user_name || '—' %>
          </td>
          <td style="padding:8px 10px;border:1px solid #e0e3e5;line-height:1.6">
            <% if (item._type === 'note') { %>
              <%= item.content %>
            <% } else { %>
              <strong><%= item.action %></strong>
              <% if (item.old_value && item.new_value) { %>
                &nbsp;— من <span style="text-decoration:line-through;color:#9ca3af"><%= item.old_value %></span>
                إلى <strong style="color:#001736"><%= item.new_value %></strong>
              <% } else if (item.new_value) { %>
                &nbsp;— <span style="color:#001736"><%= item.new_value %></span>
              <% } %>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- ── تذييل الصفحة ──────────────────────────────────────── -->
  <div style="border-top:2px solid #e0e3e5;margin-top:24px;padding-top:12px;display:flex;justify-content:flex-end;align-items:center;font-size:10px;color:#9ca3af">
    <div style="text-align:left">
      طُبع بواسطة: <strong><%= locals.adminName || adminUser %></strong>
      &nbsp;·&nbsp; بتاريخ <%= printDate %> &nbsp;·&nbsp; ملف رقم #<%= applicant.id %>
    </div>
  </div>

</div>
<!-- ═══════════════════════════════════════════════════════════ -->

<!-- Toast notification -->
<div id="toast" class="fixed bottom-6 left-6 bg-[#001736] text-white text-sm px-5 py-3 rounded-xl shadow-2xl
     transform translate-y-16 opacity-0 transition-all duration-300 z-50 flex items-center gap-2">
  <span class="material-symbols-outlined text-[#ffdf9e] text-base" id="toastIcon">check</span>
  <span id="toastMsg"></span>
</div>

<script>
const APPLICANT_ID = <%= applicant.id %>;
let selectedNoteType = 'note';

function toast(msg, icon = 'check', isError = false) {
  const el = document.getElementById('toast');
  const ic = document.getElementById('toastIcon');
  document.getElementById('toastMsg').textContent = msg;
  ic.textContent = icon;
  el.classList.toggle('bg-red-800', isError);
  el.classList.toggle('bg-[#001736]', !isError);
  el.classList.remove('translate-y-16', 'opacity-0');
  setTimeout(() => el.classList.add('translate-y-16', 'opacity-0'), 2500);
}

function selectNoteType(type) {
  selectedNoteType = type;
  document.querySelectorAll('.note-type-btn').forEach(btn => {
    const active = btn.dataset.type === type;
    btn.className = btn.className.replace(/(bg-\[#001736\] text-white border-\[#001736\]|border-\[#e0e3e5\] text-\[#43474f\] hover:bg-\[#f2f4f6\])/g, '');
    btn.classList.add(...(active
      ? ['bg-[#001736]', 'text-white', 'border-[#001736]']
      : ['border-[#e0e3e5]', 'text-[#43474f]', 'hover:bg-[#f2f4f6]']));
  });
}

function setRating(val) {
  fetch(`/admin/applicants/${APPLICANT_ID}/rating`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ rating: val })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      document.querySelectorAll('.star-btn').forEach((btn, i) => {
        btn.classList.toggle('active', i < data.rating);
      });
      toast('تم تحديث التقييم', 'star');
    }
  });
}

function updateStatus(status) {
  fetch(`/admin/applicants/${APPLICANT_ID}/status`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ status })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      toast('تم تحديث الحالة إلى: ' + data.label, 'check_circle');
      setTimeout(() => location.reload(), 800);
    }
  });
}

function addNote() {
  const content = document.getElementById('noteContent').value.trim();
  if (!content) { toast('يرجى كتابة ملاحظة', 'warning', true); return; }

  fetch(`/admin/applicants/${APPLICANT_ID}/notes`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ content, type: selectedNoteType })
  })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      document.getElementById('noteContent').value = '';
      toast('تمت إضافة الملاحظة', 'check_circle');
      setTimeout(() => location.reload(), 600);
    }
  });
}

function deleteNote(nid) {
  if (!confirm('هل تريد حذف هذه الملاحظة؟')) return;
  fetch(`/admin/applicants/${APPLICANT_ID}/notes/${nid}`, { method: 'DELETE' })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      const el = document.getElementById('note-' + nid);
      if (el) el.remove();
      toast('تم حذف الملاحظة', 'delete');
    }
  });
}

function deleteApplicant() {
  if (!confirm('هل أنت متأكد من حذف هذا المتقدم؟ لا يمكن التراجع عن هذا الإجراء.')) return;
  fetch(`/admin/applicants/${APPLICANT_ID}`, { method: 'DELETE' })
  .then(r => r.json())
  .then(data => {
    if (data.ok) {
      toast('تم حذف المتقدم', 'delete');
      setTimeout(() => location.href = '/admin/applicants', 800);
    }
  });
}
</script>
</body>
</html>
