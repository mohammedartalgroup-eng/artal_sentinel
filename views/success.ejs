<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>أرتال للحراسة الأمنية - تم استلام طلبك</title>
  <meta name="robots" content="noindex, nofollow">
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  </style>
</head>
<body class="bg-surface text-on-surface min-h-screen flex flex-col">

  <header class="bg-[#001736] w-full py-4 flex justify-center items-center">
    <div class="bg-white rounded-xl px-5 py-2 shadow-lg">
      <img src="/images/icon.png" alt="أرتال للحراسة الأمنية" class="h-12 w-auto object-contain">
    </div>
  </header>

  <main class="flex-grow flex items-center justify-center px-4 py-12 md:py-24">
    <div class="max-w-4xl w-full grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">

      <!-- Success Card -->
      <div class="bg-surface-container-lowest p-8 md:p-12 rounded-2xl flex flex-col items-center text-center justify-center shadow-sm">
        <div class="mb-8 relative">
          <div class="absolute inset-0 bg-tertiary-fixed opacity-20 rounded-full scale-150 blur-xl"></div>
          <div class="relative bg-surface-container-lowest w-24 h-24 rounded-full flex items-center justify-center">
            <span class="material-symbols-outlined text-6xl text-primary"
                  style="font-variation-settings:'FILL' 1">check_circle</span>
          </div>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold text-primary mb-6 leading-tight">
          شكراً لك! تم استلام طلبك بنجاح
          <span class="block text-xl md:text-2xl mt-2 font-normal text-on-surface-variant opacity-80">
            Thank you! Your application has been successfully submitted.
          </span>
        </h1>
        <!-- متطلبات التوظيف -->
        <div class="w-full mt-6 bg-[#f2f4f6] rounded-xl p-5 text-right border border-[#e0e3e5]">
          <div class="flex items-center gap-2 mb-3">
            <span class="material-symbols-outlined text-[#001736] text-xl" style="font-variation-settings:'FILL' 1">assignment</span>
            <h3 class="text-sm font-bold text-[#001736]">تجهيز متطلبات التوظيف</h3>
          </div>
          <p class="text-sm text-[#43474f] leading-relaxed mb-4">
            استعداداً للمرحلة القادمة وتسريعاً لإجراءات التعيين في حال قبول طلبك، يُرجى الاطلاع على نموذج متطلبات التوظيف وتجهيز المستندات المطلوبة مسبقاً.
          </p>
          <a href="https://jobs.artalsecurity.com/uploads/hiring_req.pdf"
             target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 bg-[#001736] text-white text-sm font-semibold px-5 py-2.5 rounded-lg hover:bg-[#002b5b] transition-colors shadow-sm">
            <span class="material-symbols-outlined text-base">download</span>
            تحميل نموذج المتطلبات
          </a>
        </div>

        <p class="text-base text-secondary font-medium max-w-md mt-6">
          سيقوم فريق التوظيف بمراجعة طلبك والتواصل معك قريباً.
          <span class="block text-sm mt-1 font-normal opacity-70">
            Our recruitment team will review your application and contact you soon.
          </span>
        </p>
        <div class="mt-6 h-1 w-24 bg-tertiary-fixed-dim rounded-full"></div>
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col gap-4">
        <div class="bg-surface-container-low p-6 rounded-2xl flex-grow border border-outline-variant/10">
          <h2 class="text-lg font-bold text-primary mb-5 border-r-4 border-tertiary-fixed pr-4">
            للمزيد من الاستفسارات
            <span class="block text-xs font-normal text-secondary mt-0.5">For further inquiries</span>
          </h2>
          <div class="space-y-3">

            <%
              const waRaw = settings.whatsapp || '';
              const waNum = waRaw.replace(/\D/g, '');
            %>

            <!-- WhatsApp -->
            <% if (waNum) { %>
            <a href="https://wa.me/<%= waNum %>" target="_blank" rel="noopener"
               class="flex items-center gap-4 p-4 rounded-xl bg-white hover:bg-green-50 border border-transparent hover:border-green-200 transition-all group cursor-pointer no-underline">
              <div class="w-12 h-12 rounded-xl flex-shrink-0 flex items-center justify-center text-white shadow-sm transition-transform group-hover:scale-105"
                   style="background:#25D366">
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[10px] text-secondary font-bold uppercase tracking-widest">واتساب · WhatsApp</p>
                <p class="text-base font-bold text-primary truncate" dir="ltr"><%= waRaw %></p>
              </div>
              <span class="material-symbols-outlined text-[#c4c6d0] group-hover:text-[#25D366] transition-colors text-lg">open_in_new</span>
            </a>
            <% } %>

            <!-- Phone Call -->
            <% if (settings.phone) { %>
            <a href="tel:<%= (settings.phone).replace(/\s/g,'') %>"
               class="flex items-center gap-4 p-4 rounded-xl bg-white hover:bg-blue-50 border border-transparent hover:border-blue-200 transition-all group cursor-pointer">
              <div class="w-12 h-12 rounded-xl bg-[#001736] flex-shrink-0 flex items-center justify-center text-white shadow-sm transition-transform group-hover:scale-105">
                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">call</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[10px] text-secondary font-bold uppercase tracking-widest">اتصال · Call</p>
                <p class="text-base font-bold text-primary truncate" dir="ltr"><%= settings.phone %></p>
              </div>
              <span class="material-symbols-outlined text-[#c4c6d0] group-hover:text-[#001736] transition-colors text-lg">call</span>
            </a>
            <% } %>

            <!-- Email -->
            <% if (settings.email) { %>
            <a href="mailto:<%= settings.email %>"
               class="flex items-center gap-4 p-4 rounded-xl bg-white hover:bg-indigo-50 border border-transparent hover:border-indigo-200 transition-all group cursor-pointer">
              <div class="w-12 h-12 rounded-xl bg-[#405f91] flex-shrink-0 flex items-center justify-center text-white shadow-sm transition-transform group-hover:scale-105">
                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">mail</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[10px] text-secondary font-bold uppercase tracking-widest">ايميل · Email</p>
                <p class="text-sm font-bold text-primary truncate" dir="ltr"><%= settings.email %></p>
              </div>
              <span class="material-symbols-outlined text-[#c4c6d0] group-hover:text-[#405f91] transition-colors text-lg">open_in_new</span>
            </a>
            <% } %>

            <!-- Maps -->
            <% if (settings.address) { %>
            <%
              const mapsHref = (settings.maps_url || '').trim()
                ? settings.maps_url.trim()
                : 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(settings.address);
            %>
            <a href="<%= mapsHref %>"
               target="_blank" rel="noopener"
               class="flex items-center gap-4 p-4 rounded-xl bg-white hover:bg-red-50 border border-transparent hover:border-red-200 transition-all group cursor-pointer">
              <div class="w-12 h-12 rounded-xl bg-[#e53935] flex-shrink-0 flex items-center justify-center text-white shadow-sm transition-transform group-hover:scale-105">
                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1">location_on</span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-[10px] text-secondary font-bold uppercase tracking-widest">الموقع · Location</p>
                <p class="text-sm font-bold text-primary truncate"><%= settings.address %></p>
              </div>
              <span class="material-symbols-outlined text-[#c4c6d0] group-hover:text-[#e53935] transition-colors text-lg">open_in_new</span>
            </a>
            <% } %>

          </div>
        </div>
        <!-- Brand bar -->
        <div class="relative h-16 rounded-2xl overflow-hidden bg-primary-container flex items-center justify-between px-6">
          <div class="text-white/40 text-[10px] font-bold tracking-[0.3em] uppercase">Trusted Protection</div>
          <div class="w-8 h-8 rounded-full border border-tertiary-fixed/30 flex items-center justify-center">
            <div class="w-2 h-2 rounded-full bg-tertiary-fixed"></div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <footer class="bg-surface border-t border-slate-200 py-8">
    <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex items-center gap-4">
        <img src="/images/icon.png" alt="أرتال" class="h-9 w-auto object-contain opacity-75 hover:opacity-100 transition-opacity">
        <span class="text-sm text-slate-400">© <%= new Date().getFullYear() %> All Rights Reserved.</span>
      </div>
      <div class="flex flex-wrap justify-center gap-6 text-sm text-slate-500">
        <% if (settings.phone) { %>
        <a href="tel:<%= (settings.phone).replace(/\s/g,'') %>" class="hover:text-slate-800 transition-colors" dir="ltr"><%= settings.phone %></a>
        <% } %>
        <% if (settings.email) { %>
        <a href="mailto:<%= settings.email %>" class="hover:text-slate-800 transition-colors"><%= settings.email %></a>
        <% } %>
        <% if (settings.address) { %>
        <%
          const footerMapsHref = (settings.maps_url || '').trim()
            ? settings.maps_url.trim()
            : 'https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(settings.address);
        %>
        <a href="<%= footerMapsHref %>" target="_blank" rel="noopener" class="hover:text-slate-800 transition-colors"><%= settings.address %></a>
        <% } %>
      </div>
    </div>
  </footer>

</body>
</html>
