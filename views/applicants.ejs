<!DOCTYPE html>
<html dir="rtl" lang="ar">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>المتقدمون — أرتال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link
    href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
    rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background: #f2f4f6;
    }

    h1,
    h2,
    h3 {
      font-family: 'Manrope', sans-serif;
    }

    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    select,
    input[type="text"],
    input[type="number"],
    input[type="date"] {
      background: white;
      border: 1px solid #e0e3e5;
      border-radius: 0.75rem;
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      width: 100%;
      outline: none;
      transition: border-color 0.15s;
    }

    select:focus,
    input:focus {
      border-color: #7594ca;
    }
  </style>
</head>

<body class="text-[#191c1e]">
  <%- include('partials/sidebar', { currentPage: 'applicants' }) %>

    <div class="lg:mr-64 min-h-screen pt-14 lg:pt-0">
      <!-- Top bar -->
      <header class="bg-white border-b border-[#eceef0] px-4 lg:px-8 py-4 lg:py-5 flex items-center justify-between sticky top-14 lg:top-0 z-30">
        <div>
          <h1 class="text-xl font-bold text-[#001736]">المتقدمون</h1>
          <p class="text-xs text-[#43474f] mt-0.5">
            إجمالي النتائج: <strong>
              <%= total %>
            </strong> متقدم
          </p>
        </div>
        <%
          const _exportParams = new URLSearchParams();
          for (const [k, v] of Object.entries(filters)) {
            if (Array.isArray(v)) v.forEach(x => { if (x !== '' && x != null) _exportParams.append(k, x); });
            else if (v !== '' && v != null) _exportParams.append(k, v);
          }
        %>
        <a href="/admin/applicants/export?<%= _exportParams.toString() %>"
          class="bg-green-700 text-white text-sm font-medium px-5 py-2.5 rounded-xl flex items-center gap-2 hover:bg-green-800 transition-colors">
          <span class="material-symbols-outlined text-base">download</span>
          تصدير Excel
        </a>
      </header>

      <main class="p-4 lg:p-8 space-y-4 lg:space-y-6">

        <!-- Filter Panel -->
        <form method="GET" action="/admin/applicants" id="filterForm">
          <div class="bg-white rounded-2xl p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="font-bold text-[#001736] text-sm flex items-center gap-2">
                <span class="material-symbols-outlined text-base">filter_list</span>
                الفلترة والبحث
              </h2>
              <a href="/admin/applicants" class="text-xs text-[#405f91] hover:underline flex items-center gap-1">
                <span class="material-symbols-outlined text-sm">refresh</span>
                إعادة تعيين
              </a>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-3">

              <!-- Search -->
              <div class="col-span-2">
                <label class="block text-xs text-[#43474f] font-semibold mb-1">بحث بالاسم / الهوية / الجوال</label>
                <div class="relative">
                  <input type="text" name="q" value="<%= filters.q %>" placeholder="اكتب للبحث...">
                  <span
                    class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-[#43474f] text-base">search</span>
                </div>
              </div>

              <!-- Status -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">الحالة</label>
                <select name="status">
                  <option value="">الكل</option>
                  <% Object.entries(STATUS_META).forEach(([k,v])=> { %>
                    <option value="<%= k %>" <%=filters.status===k ? 'selected' : '' %>><%= v.label %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <!-- Region -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">المنطقة</label>
                <select name="region" id="region-filter">
                  <option value="">الكل</option>
                  <% REGIONS.forEach(r=> { %>
                    <option value="<%= r %>" <%=filters.region===r ? 'selected' : '' %>><%= r %>
                    </option>
                    <% }) %>
                </select>
              </div>

              <!-- City (multi-select, dynamic) -->
              <div class="relative" id="city-multi">
                <label class="block text-xs text-[#43474f] font-semibold mb-1">المدينة</label>
                <button type="button" id="city-toggle"
                  class="w-full bg-white border border-[#e0e3e5] rounded-xl px-3 py-2 text-sm text-right flex items-center justify-between hover:border-[#7594ca] transition-colors">
                  <span id="city-label" class="truncate text-[#43474f]">الكل</span>
                  <span class="material-symbols-outlined text-base text-[#43474f]">expand_more</span>
                </button>
                <select name="city" id="city-filter" multiple class="hidden"></select>
                <div id="city-panel"
                  class="hidden absolute z-40 mt-1 w-72 max-w-[90vw] bg-white border border-[#e0e3e5] rounded-xl shadow-lg right-0">
                  <div class="p-2 border-b border-[#eceef0]">
                    <input type="text" id="city-search" placeholder="ابحث عن مدينة..."
                      class="!py-1.5 !text-sm">
                  </div>
                  <div id="city-options" class="max-h-56 overflow-y-auto py-1">
                    <p class="text-xs text-[#43474f] text-center py-3" id="city-empty">اختر المنطقة أولاً</p>
                  </div>
                  <div class="p-2 border-t border-[#eceef0] flex items-center justify-between text-xs">
                    <button type="button" id="city-clear" class="text-red-600 hover:underline">مسح الكل</button>
                    <button type="button" id="city-close"
                      class="bg-[#001736] text-white px-3 py-1 rounded-md hover:bg-[#002b5b]">تم</button>
                  </div>
                </div>
              </div>

              <!-- Gender -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">الجنس</label>
                <select name="gender">
                  <option value="">الكل</option>
                  <option value="male" <%=filters.gender==='male' ? 'selected' : '' %>>ذكر</option>
                  <option value="female" <%=filters.gender==='female' ? 'selected' : '' %>>أنثى</option>
                </select>
              </div>

              <!-- English -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">الإنجليزية</label>
                <select name="english">
                  <option value="">الكل</option>
                  <option value="1" <%=filters.english==='1' ? 'selected' : '' %>>يجيد</option>
                  <option value="0" <%=filters.english==='0' ? 'selected' : '' %>>لا يجيد</option>
                </select>
              </div>

              <!-- Qualification -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">المؤهل</label>
                <select name="qualification">
                  <option value="">الكل</option>
                  <option value="none" <%=filters.qualification==='none' ? 'selected' : '' %>>بدون مؤهل</option>
                  <option value="primary" <%=filters.qualification==='primary' ? 'selected' : '' %>>ابتدائي</option>
                  <option value="middle" <%=filters.qualification==='middle' ? 'selected' : '' %>>متوسط</option>
                  <option value="high_school" <%=filters.qualification==='high_school' ? 'selected' : '' %>>ثانوي
                  </option>
                  <option value="university" <%=filters.qualification==='university' ? 'selected' : '' %>>جامعي</option>
                </select>
              </div>

              <!-- Has Car -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">سيارة</label>
                <select name="has_car">
                  <option value="">الكل</option>
                  <option value="1" <%=filters.has_car==='1' ? 'selected' : '' %>>نعم</option>
                  <option value="0" <%=filters.has_car==='0' ? 'selected' : '' %>>لا</option>
                </select>
              </div>

              <!-- Has License -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">رخصة</label>
                <select name="has_license">
                  <option value="">الكل</option>
                  <option value="1" <%=filters.has_license==='1' ? 'selected' : '' %>>نعم</option>
                  <option value="0" <%=filters.has_license==='0' ? 'selected' : '' %>>لا</option>
                </select>
              </div>

              <!-- Ext Check (النظام السابق) -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">قاعدة البيات</label>
                <select name="ext_check">
                  <option value="">الكل</option>
                  <option value="found" <%=filters.ext_check==='found' ? 'selected' : '' %>>موجود</option>
                  <option value="not_found" <%=filters.ext_check==='not_found' ? 'selected' : '' %>>غير موجود</option>
                  <option value="unchecked" <%=filters.ext_check==='unchecked' ? 'selected' : '' %>>لم يُفحص</option>
                </select>
              </div>

              <!-- Age range -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">العمر من</label>
                <input type="number" name="age_min" value="<%= filters.age_min %>" placeholder="18" min="1" max="99">
              </div>
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">إلى</label>
                <input type="number" name="age_max" value="<%= filters.age_max %>" placeholder="60" min="1" max="99">
              </div>

              <!-- Date range -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">من تاريخ</label>
                <input type="date" name="date_from" value="<%= filters.date_from %>">
              </div>
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">إلى تاريخ</label>
                <input type="date" name="date_to" value="<%= filters.date_to %>">
              </div>

              <!-- Sort -->
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">ترتيب بـ</label>
                <select name="sort">
                  <option value="created_at" <%=filters.sort==='created_at' ? 'selected' :'' %>>تاريخ التقديم</option>
                  <option value="full_name" <%=filters.sort==='full_name' ? 'selected' :'' %>>الاسم</option>
                  <option value="age" <%=filters.sort==='age' ? 'selected' :'' %>>العمر</option>
                  <option value="rating" <%=filters.sort==='rating' ? 'selected' :'' %>>التقييم</option>
                </select>
              </div>
              <div>
                <label class="block text-xs text-[#43474f] font-semibold mb-1">الاتجاه</label>
                <select name="order">
                  <option value="desc" <%=filters.order==='desc' ? 'selected' :'' %>>الأحدث أولاً</option>
                  <option value="asc" <%=filters.order==='asc' ? 'selected' :'' %>>الأقدم أولاً</option>
                </select>
              </div>

              <!-- Submit -->
              <div class="flex items-end">
                <button type="submit"
                  class="w-full bg-[#001736] text-white text-sm font-semibold py-2.5 rounded-xl hover:bg-[#002b5b] transition-colors flex items-center justify-center gap-1.5">
                  <span class="material-symbols-outlined text-base">search</span>
                  بحث
                </button>
              </div>
            </div>
          </div>
        </form>

        <!-- Table -->
        <div class="bg-white rounded-2xl overflow-hidden">
          <% if (applicants.length===0) { %>
            <div class="text-center py-16 text-[#43474f]">
              <span class="material-symbols-outlined text-5xl block mb-3 text-[#c4c6d0]">search_off</span>
              لا توجد نتائج تطابق الفلتر المحدد
            </div>
            <% } else { %>
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-[#f8f9fb] border-b border-[#eceef0]">
                    <tr class="text-[#43474f] text-xs">
                      <th class="text-right px-5 py-4 font-semibold">الاسم</th>
                      <th class="text-right px-4 py-4 font-semibold">الهوية</th>
                      <th class="text-right px-4 py-4 font-semibold">الجوال</th>
                      <th class="text-right px-4 py-4 font-semibold">العمر</th>
                      <th class="text-center px-4 py-4 font-semibold">الجنس</th>
                      <th class="text-right px-4 py-4 font-semibold">المنطقة / المدينة</th>
                      <th class="text-center px-4 py-4 font-semibold">سيارة</th>
                      <th class="text-center px-4 py-4 font-semibold">رخصة</th>
                      <th class="text-center px-3 py-4 font-semibold">سابق</th>
                      <th class="text-right px-4 py-4 font-semibold">الحالة</th>
                      <th class="text-right px-4 py-4 font-semibold">التقييم</th>
                      <th class="text-right px-4 py-4 font-semibold">التاريخ</th>
                      <th class="px-4 py-4"></th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-[#f2f4f6]">
                    <% const colorMap={ blue:'bg-blue-100 text-blue-700', yellow:'bg-yellow-100 text-yellow-800', purple:'bg-purple-100 text-purple-700', orange:'bg-orange-100 text-orange-700', green:'bg-green-100 text-green-700', gray:'bg-gray-100 text-gray-600', red:'bg-red-100 text-red-700' }; %>
                      <% applicants.forEach(a=> { %>
                        <% const sm=STATUS_META[a.status] || { label: a.status, color: 'gray' }; %>
                          <tr class="hover:bg-[#f8f9fb] transition-colors cursor-pointer"
                            onclick="location.href='/admin/applicants/<%= a.id %>'">
                            <td class="px-5 py-3.5 font-medium text-[#001736]">
                              <%= a.full_name %>
                            </td>
                            <td class="px-4 py-3.5 text-[#43474f] font-mono text-xs">
                              <%= a.id_number %>
                            </td>
                            <td class="px-4 py-3.5 text-[#43474f]" dir="ltr">
                              <%= a.phone %>
                            </td>
                            <td class="px-4 py-3.5 text-[#43474f]">
                              <%= a.age || '—' %>
                            </td>
                            <td class="px-4 py-3.5 text-center text-xs font-medium">
                              <% if (a.gender==='male' ) { %>
                                <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">ذكر</span>
                                <% } else if (a.gender==='female' ) { %>
                                  <span class="px-2 py-0.5 rounded-full bg-pink-100 text-pink-700">أنثى</span>
                                  <% } else { %>
                                    <span class="text-[#c4c6d0]">—</span>
                                    <% } %>
                            </td>
                            <td class="px-4 py-3.5 text-[#43474f]">
                              <% if (a.region) { %>
                                <div class="text-xs text-[#7594ca] font-medium">
                                  <%= a.region %>
                                </div>
                                <% } %>
                                  <div>
                                    <%= a.city || '—' %>
                                  </div>
                                  <% if (a.neighborhood) { %>
                                    <div class="text-xs text-[#9ca3af]">
                                      <%= a.neighborhood %>
                                    </div>
                                    <% } %>
                            </td>
                            <td class="px-4 py-3.5 text-center">
                              <span
                                class="material-symbols-outlined text-base <%= a.has_car ? 'text-green-600' : 'text-[#c4c6d0]' %>">
                                <%= a.has_car ? 'directions_car' : 'block' %>
                              </span>
                            </td>
                            <td class="px-4 py-3.5 text-center">
                              <span
                                class="material-symbols-outlined text-base <%= a.has_license ? 'text-green-600' : 'text-[#c4c6d0]' %>">
                                <%= a.has_license ? 'badge' : 'block' %>
                              </span>
                            </td>
                            <td class="px-3 py-3.5 text-center">
                              <% if (!a.ext_check_done) { %>
                                <span class="material-symbols-outlined text-base text-[#d1d5db]"
                                  title="لم يُفحص بعد">circle</span>
                                <% } else if (a.ext_found) { %>
                                  <span class="material-symbols-outlined text-base text-green-500"
                                    title="موجود في النظام السابق"
                                    style="font-variation-settings:'FILL' 1">check_circle</span>
                                  <% } else { %>
                                    <span class="material-symbols-outlined text-base text-[#d1d5db]"
                                      title="غير موجود في النظام السابق">remove_circle</span>
                                    <% } %>
                            </td>
                            <td class="px-4 py-3.5">
                              <span
                                class="px-2.5 py-1 rounded-full text-xs font-semibold whitespace-nowrap <%= colorMap[sm.color] %>">
                                <%= sm.label %>
                              </span>
                            </td>
                            <td class="px-4 py-3.5">
                              <span class="text-[#ffdf9e] text-base" style="font-family:monospace">
                                <%= '★' .repeat(a.rating) %>
                                  <%= '☆' .repeat(5 - a.rating) %>
                              </span>
                            </td>
                            <td class="px-4 py-3.5 text-[#43474f] text-xs whitespace-nowrap">
                              <%= fmtDate(a.created_at) %>
                            </td>
                            <td class="px-4 py-3.5">
                              <a href="/admin/applicants/<%= a.id %>" onclick="event.stopPropagation()"
                                class="text-[#405f91] hover:underline text-xs flex items-center gap-1 whitespace-nowrap">
                                <span class="material-symbols-outlined text-sm">open_in_new</span>
                                عرض
                              </a>
                            </td>
                          </tr>
                          <% }) %>
                  </tbody>
                </table>
              </div>

              <!-- Pagination -->
              <!-- Pagination -->
                <div class="flex items-center justify-between px-6 py-4 border-t border-[#f2f4f6] flex-wrap gap-3">

                  <!-- عرض X–Y من Z -->
                  <% const _from = (pageNum - 1) * 20 + 1; const _to = _from + applicants.length - 1; %>
                  <span class="text-xs text-[#43474f]">
                    عرض <span class="font-semibold text-[#001736]"><%= _from %>–<%= _to %></span>
                    من <span class="font-semibold text-[#001736]"><%= total %></span> متقدم
                  </span>

                  <% if (totalPages > 1) { %>
                  <div class="flex items-center gap-1">

                    <%/* ── زر السابق ── */%>
                    <% if (pageNum > 1) { %>
                      <a href="?<%= new URLSearchParams({...filters, page: pageNum - 1}).toString() %>"
                         class="flex items-center gap-0.5 px-3 h-9 rounded-lg bg-[#f2f4f6] hover:bg-[#e4e6e9] text-sm font-medium text-[#43474f] transition-colors select-none">
                        <span class="material-symbols-outlined" style="font-size:18px">chevron_right</span>السابق
                      </a>
                    <% } else { %>
                      <span class="flex items-center gap-0.5 px-3 h-9 rounded-lg text-sm font-medium text-[#c4c6d0] select-none cursor-not-allowed">
                        <span class="material-symbols-outlined" style="font-size:18px">chevron_right</span>السابق
                      </span>
                    <% } %>

                    <%/* ── أرقام الصفحات مع النقاط ── */%>
                    <%
                      const _pSet = new Set([1, totalPages]);
                      for (let _i = Math.max(1, pageNum-2); _i <= Math.min(totalPages, pageNum+2); _i++) _pSet.add(_i);
                      const _pSorted = [..._pSet].sort((a,b) => a-b);
                      const _pItems = [];
                      for (let _i = 0; _i < _pSorted.length; _i++) {
                        if (_i > 0) {
                          const _gap = _pSorted[_i] - _pSorted[_i-1];
                          if (_gap === 2) _pItems.push(_pSorted[_i] - 1); // صفحة واحدة مخفية → اعرضها مباشرة
                          else if (_gap > 2) _pItems.push('…');           // أكثر من واحدة → نقاط
                        }
                        _pItems.push(_pSorted[_i]);
                      }
                    %>
                    <% _pItems.forEach(_p => { %>
                      <% if (_p === '…') { %>
                        <span class="w-9 h-9 flex items-center justify-center text-[#9ca3af] text-sm select-none">…</span>
                      <% } else { %>
                        <a href="?<%= new URLSearchParams({...filters, page: _p}).toString() %>"
                           class="w-9 h-9 rounded-lg text-sm font-semibold flex items-center justify-center transition-colors select-none <%= _p === pageNum ? 'bg-[#001736] text-white' : 'bg-[#f2f4f6] hover:bg-[#e4e6e9] text-[#191c1e]' %>">
                          <%= _p %>
                        </a>
                      <% } %>
                    <% }) %>

                    <%/* ── زر التالي ── */%>
                    <% if (pageNum < totalPages) { %>
                      <a href="?<%= new URLSearchParams({...filters, page: pageNum + 1}).toString() %>"
                         class="flex items-center gap-0.5 px-3 h-9 rounded-lg bg-[#f2f4f6] hover:bg-[#e4e6e9] text-sm font-medium text-[#43474f] transition-colors select-none">
                        التالي<span class="material-symbols-outlined" style="font-size:18px">chevron_left</span>
                      </a>
                    <% } else { %>
                      <span class="flex items-center gap-0.5 px-3 h-9 rounded-lg text-sm font-medium text-[#c4c6d0] select-none cursor-not-allowed">
                        التالي<span class="material-symbols-outlined" style="font-size:18px">chevron_left</span>
                      </span>
                    <% } %>

                  </div>
                  <% } %>
                </div>
                  <% } %>
        </div>

      </main>
    </div>

    <script>
      const SA_REGIONS_DATA = <%- JSON.stringify(SA_REGIONS) %>;
      const PRE_SELECTED_CITIES = <%- JSON.stringify(Array.isArray(filters.city) ? filters.city : (filters.city ? [filters.city] : [])) %>;

      const regionEl = document.getElementById('region-filter');
      const citySelect = document.getElementById('city-filter');
      const cityToggle = document.getElementById('city-toggle');
      const cityPanel = document.getElementById('city-panel');
      const cityOptions = document.getElementById('city-options');
      const cityEmpty = document.getElementById('city-empty');
      const cityLabel = document.getElementById('city-label');
      const citySearch = document.getElementById('city-search');
      const cityClear = document.getElementById('city-clear');
      const cityClose = document.getElementById('city-close');

      function getCityListForRegion() {
        const r = regionEl.value;
        if (!r) return [];
        const found = SA_REGIONS_DATA.find(x => x.name === r);
        return found ? found.cities : [];
      }

      function rebuildCityOptions(preselected) {
        const cities = getCityListForRegion();
        citySelect.innerHTML = '';
        cityOptions.innerHTML = '';

        if (!cities.length) {
          cityEmpty.classList.remove('hidden');
          cityOptions.appendChild(cityEmpty);
          updateCityLabel();
          return;
        }
        cityEmpty.classList.add('hidden');

        cities.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c;
          opt.textContent = c;
          if (preselected.includes(c)) opt.selected = true;
          citySelect.appendChild(opt);

          const row = document.createElement('label');
          row.className = 'flex items-center gap-2 px-3 py-1.5 hover:bg-[#f2f4f6] cursor-pointer text-sm';
          row.dataset.cityName = c;
          row.innerHTML =
            '<input type="checkbox" class="w-4 h-4 accent-[#001736]" ' +
            (preselected.includes(c) ? 'checked' : '') + '>' +
            '<span>' + c + '</span>';
          const cb = row.querySelector('input');
          cb.addEventListener('change', () => {
            for (const o of citySelect.options) {
              if (o.value === c) { o.selected = cb.checked; break; }
            }
            updateCityLabel();
          });
          cityOptions.appendChild(row);
        });
        updateCityLabel();
      }

      function updateCityLabel() {
        const selected = Array.from(citySelect.selectedOptions).map(o => o.value);
        if (selected.length === 0) {
          cityLabel.textContent = 'الكل';
          cityLabel.classList.add('text-[#43474f]');
        } else if (selected.length === 1) {
          cityLabel.textContent = selected[0];
          cityLabel.classList.remove('text-[#43474f]');
        } else {
          cityLabel.textContent = selected.length + ' مدن مختارة';
          cityLabel.classList.remove('text-[#43474f]');
        }
      }

      cityToggle.addEventListener('click', e => {
        e.stopPropagation();
        cityPanel.classList.toggle('hidden');
        if (!cityPanel.classList.contains('hidden')) citySearch.focus();
      });

      document.addEventListener('click', e => {
        if (!document.getElementById('city-multi').contains(e.target)) {
          cityPanel.classList.add('hidden');
        }
      });

      cityClose.addEventListener('click', () => cityPanel.classList.add('hidden'));

      cityClear.addEventListener('click', () => {
        for (const o of citySelect.options) o.selected = false;
        cityOptions.querySelectorAll('input[type=checkbox]').forEach(cb => cb.checked = false);
        updateCityLabel();
      });

      citySearch.addEventListener('input', () => {
        const term = citySearch.value.trim();
        cityOptions.querySelectorAll('label[data-city-name]').forEach(row => {
          row.style.display = !term || row.dataset.cityName.includes(term) ? '' : 'none';
        });
      });

      regionEl.addEventListener('change', () => {
        rebuildCityOptions([]);
        citySearch.value = '';
      });

      rebuildCityOptions(PRE_SELECTED_CITIES);
    </script>
</body>

</html>