<%
  // تواريخ ديناميكية حتى يبقى إعلان الوظيفة "طازجاً" في نتائج جوجل للوظائف.
  // datePosted نصف شهري: يُثبَّت على 1 أو 16 من الشهر الحالي — أقصى عمر للإعلان 15 يوماً
  // (بدل 30 سابقاً)، دون أن يصير "اليوم" عند كل زحف. مكوّنات UTC مقصودة.
  const _today = new Date();
  const _y  = _today.getUTCFullYear();
  const _m  = String(_today.getUTCMonth() + 1).padStart(2, '0');
  const _d  = _today.getUTCDate() >= 16 ? '16' : '01';
  const datePosted  = `${_y}-${_m}-${_d}`;
  const validThrough = new Date(_today.getTime() + 60 * 86400000).toISOString().split('T')[0];
  const roleSeg = role.urlSegment ? '/' + role.urlSegment : '';
  const pageUrl = 'https://jobs.artalsecurity.com/jobs/' + city.slug + roleSeg;
  const title = 'وظائف ' + role.title + ' في ' + city.city + ' | أرتال للحراسات الأمنية';
  const desc  = 'وظائف ' + role.title + ' في ' + city.city + ' لدى شركة أرتال للحراسات الأمنية: تأمين ' + city.sites.slice(0, 3).join('، ') + '. رواتب تنافسية، جداول عمل مرنة وتدريب معتمد. التقديم مجاني وإلكتروني.';
  const roleIntro = role.roleIntro(city);
  // قنوات التواصل — لإشارة الكيان (sameAs) والتذييل المرئي
  const socialLinks = [
    { name: 'LinkedIn',     url: 'https://www.linkedin.com/company/artalgroup/' },
    { name: 'Instagram',    url: 'https://www.instagram.com/artal_group.sa/' },
    { name: 'X (تويتر)',    url: 'https://twitter.com/ArtalGroupSA' },
    { name: 'YouTube',      url: 'https://www.youtube.com/@ArtalGroup' },
    { name: 'Telegram',     url: 'https://t.me/artalgroup1' },
    { name: 'Snapchat',     url: 'https://t.snapchat.com/O9T1Eyj9' },
  ];
  const appLinks = [
    'https://play.google.com/store/apps/details?id=com.intshar.artalapp',
    'https://apps.apple.com/us/app/artal/id6740813953',
  ];
  const sameAs = ['https://artalsecurity.com', 'https://jobs.artalsecurity.com', ...socialLinks.map(s => s.url), ...appLinks];
%><!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title><%= title %></title>
  <meta name="description" content="<%= desc %>">
  <meta name="keywords" content="وظائف <%= role.title %> <%= city.city %>, وظائف <%= role.title %> في <%= city.city %>, توظيف <%= role.plural %> <%= city.city %>, شركة حراسات أمنية <%= city.city %>, وظائف أمن <%= city.region %>, راتب <%= role.title %> <%= city.city %>, تقديم وظائف حراسة <%= city.city %>, أرتال للحراسة الأمنية">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="<%= pageUrl %>">

  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= pageUrl %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= desc %>">
  <meta property="og:locale" content="ar_SA">
  <meta property="og:site_name" content="أرتال للحراسات الأمنية">
  <meta property="og:image" content="https://jobs.artalsecurity.com/images/icon.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= desc %>">
  <meta name="twitter:image" content="https://jobs.artalsecurity.com/images/icon.png">
  <link rel="icon" type="image/png" href="/images/icon.png">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "JobPosting",
        "title": "<%= role.title %> — <%= city.city %>",
        "description": "تبحث شركة أرتال للحراسات الأمنية المدنية الخاصة عن كفاءات وطنية للعمل كـ<%= role.plural %> في مدينة <%= city.city %> ضمن <%= city.region %>. <%= roleIntro %> تشمل مواقع العمل <%= city.sites.join('، ') %>. المهام: <%= role.duties.join('؛ ') %>. <%= role.faqRequirements %> نوفّر رواتب تنافسية وجداول عمل مرنة وتدريباً معتمداً. التقديم مجاني وإلكتروني بالكامل.",
        "identifier": {
          "@type": "PropertyValue",
          "name": "أرتال للحراسات الأمنية المدنية الخاصة",
          "value": "artal-security-<%= role.slug %>-<%= city.slug %>"
        },
        "hiringOrganization": {
          "@type": "Organization",
          "@id": "https://artalsecurity.com/#organization",
          "name": "أرتال للحراسات الأمنية المدنية الخاصة",
          "sameAs": <%- JSON.stringify(sameAs) %>,
          "logo": "https://jobs.artalsecurity.com/images/icon.png"
        },
        "jobLocation": {
          "@type": "Place",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "<%= city.city %>",
            "addressRegion": "<%= city.region %>",
            "addressCountry": "SA"
          }
        },
        "employmentType": "<%= role.employmentType %>",
        "directApply": true,
        "datePosted": "<%= datePosted %>",
        "validThrough": "<%= validThrough %>",
        "applicantLocationRequirements": { "@type": "Country", "name": "SA" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": "https://jobs.artalsecurity.com/" },
          { "@type": "ListItem", "position": 2, "name": "وظائف <%= role.title %> في <%= city.city %>", "item": "<%= pageUrl %>" }
        ]
      },
      {
        "@type": "FAQPage",
        "mainEntity": [
          { "@type": "Question", "name": "كم راتب <%= role.title %> في <%= city.city %>؟",
            "acceptedAnswer": { "@type": "Answer", "text": "<%= role.faqSalary %>" } },
          { "@type": "Question", "name": "هل التقديم على وظائف الحراسة في <%= city.city %> مجاني؟",
            "acceptedAnswer": { "@type": "Answer", "text": "نعم، التقديم إلكتروني ومجاني تماماً عبر موقع أرتال، ولا توجد أي رسوم على المتقدمين." } },
          { "@type": "Question", "name": "ما شروط القبول كـ<%= role.title %> في <%= city.city %>؟",
            "acceptedAnswer": { "@type": "Answer", "text": "<%= role.faqRequirements %>" } },
          { "@type": "Question", "name": "هل يوجد توظيف فوري لوظائف <%= role.title %> في <%= city.city %>؟",
            "acceptedAnswer": { "@type": "Answer", "text": "نعم، نستقبل طلبات التوظيف بشكل مستمر في <%= city.city %> وتتم مراجعتها أولاً بأول، مع إمكانية المباشرة السريعة حسب احتياج المواقع مثل <%= city.sites[0] %>." } },
          { "@type": "Question", "name": "هل تتطلب وظيفة <%= role.title %> في <%= city.city %> خبرة سابقة؟",
            "acceptedAnswer": { "@type": "Answer", "text": "<%= role.faqExperience %>" } }
        ]
      }
    ]
  }
  </script>

  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" onload="this.onload=null;this.rel='stylesheet'"><noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap"></noscript>
  <style>
    body { background:#f8f9fb; font-family:'Inter',sans-serif; color:#191c1e; }
    h1,h2,h3 { font-family:'Manrope',sans-serif; }
  </style>
</head>
<body>
  <!-- Header -->
  <header class="bg-primary text-white">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3">
        <img src="/images/icon.png" alt="أرتال للحراسات الأمنية" class="h-10 w-auto">
        <span class="font-bold">أرتال للحراسات الأمنية</span>
      </a>
      <a href="/" class="bg-white text-primary text-sm font-bold px-5 py-2 rounded-lg hover:bg-slate-100 transition">قدّم الآن</a>
    </div>
  </header>

  <!-- Hero -->
  <section class="bg-primary text-white">
    <div class="max-w-5xl mx-auto px-6 pb-16 pt-8 text-center">
      <nav class="text-xs text-slate-300 mb-6" aria-label="breadcrumb">
        <a href="/" class="hover:text-white">الرئيسية</a>
        <span class="mx-2">/</span>
        <% if (role.urlSegment) { %>
          <a href="/jobs/<%= city.slug %>" class="hover:text-white">وظائف <%= city.city %></a>
          <span class="mx-2">/</span>
        <% } %>
        <span>وظائف <%= role.title %> في <%= city.city %></span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-extrabold mb-5 leading-tight">
        وظائف <%= role.title %> في <%= city.city %>
      </h1>
      <p class="text-slate-200 text-lg max-w-2xl mx-auto leading-relaxed">
        تعلن شركة أرتال للحراسات الأمنية المدنية الخاصة عن حاجتها لـ<%= role.plural %> في <%= city.city %> ضمن <%= city.region %>.
        رواتب تنافسية، جداول عمل مرنة وتدريب معتمد.
      </p>
      <a href="/" class="inline-block mt-8 bg-white text-primary font-bold px-8 py-3.5 rounded-xl shadow-lg hover:bg-slate-100 transition">
        قدّم على الوظيفة الآن
      </a>
    </div>
  </section>

  <main class="max-w-3xl mx-auto px-6 py-14 space-y-12">

    <!-- مقدمة المدينة -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">عن وظيفة <%= role.title %> في <%= city.city %></h2>
      <p class="leading-loose text-slate-700">
        <%= city.intro %>
        <%= roleIntro %>
      </p>
    </section>

    <!-- المهام والمسؤوليات -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">مهام <%= role.title %> في <%= city.city %></h2>
      <ul class="space-y-2 text-slate-700 leading-loose list-disc pr-5">
        <% role.duties.forEach(d => { %>
          <li><%= d %></li>
        <% }) %>
      </ul>
    </section>

    <!-- أنواع المواقع التي نؤمّنها في المدينة -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">أين يعمل <%= role.title %> في <%= city.city %>؟</h2>
      <p class="leading-loose text-slate-700 mb-4">
        تتنوّع مواقع العمل في <%= city.city %> حسب طبيعة المنشأة، ومن أبرز ما نؤمّنه:
      </p>
      <ul class="grid sm:grid-cols-2 gap-3 text-slate-700">
        <% city.sites.forEach(s => { %>
          <li class="bg-white border border-slate-200 rounded-xl p-4 flex items-center gap-3">
            <span class="text-primary">🛡️</span><span><%= s %></span>
          </li>
        <% }) %>
      </ul>
    </section>

    <!-- أحياء/مواقع العمل داخل المدينة (اختياري — يظهر عند توفّر أحياء) -->
    <% if (city.districts && city.districts.length) { %>
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">نخدم جميع أحياء <%= city.city %></h2>
      <p class="leading-loose text-slate-700 mb-4">
        تشمل فرص العمل كـ<%= role.title %> مختلف أحياء ومواقع <%= city.city %>، ومنها:
      </p>
      <div class="flex flex-wrap gap-2">
        <% city.districts.forEach(d => { %>
          <span class="text-sm bg-white border border-slate-200 rounded-full px-4 py-2 text-slate-700"><%= d %></span>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- المزايا -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">مزايا العمل في أرتال</h2>
      <ul class="grid sm:grid-cols-2 gap-3 text-slate-700">
        <li class="bg-white border border-slate-200 rounded-xl p-4">💰 رواتب تنافسية</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4">🕒 جداول عمل مرنة</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4">🎓 تدريب معتمد قبل المباشرة</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4">📈 فرص ترقّي واستقرار وظيفي</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4">🛡️ بيئة عمل نظامية وآمنة</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4">🗓️ مواقع عمل متعددة في <%= city.city %></li>
      </ul>
    </section>

    <!-- الشروط -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">شروط القبول لوظيفة <%= role.title %></h2>
      <ul class="space-y-2 text-slate-700 leading-loose list-disc pr-5">
        <% role.requirements.forEach(r => { %>
          <li><%- r %></li>
        <% }) %>
      </ul>
    </section>

    <!-- خطوات التقديم -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">خطوات التقديم في <%= city.city %></h2>
      <ol class="space-y-3 text-slate-700">
        <li class="bg-white border border-slate-200 rounded-xl p-4"><strong>1.</strong> عبّئ نموذج التقديم الإلكتروني (أقل من دقيقة).</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4"><strong>2.</strong> أرفق صورة الهوية الوطنية والسيرة الذاتية.</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4"><strong>3.</strong> تتم مراجعة طلبك والتواصل معك في حال القبول المبدئي.</li>
        <li class="bg-white border border-slate-200 rounded-xl p-4"><strong>4.</strong> اجتياز التدريب ثم المباشرة في العمل.</li>
      </ol>
      <div class="text-center mt-8">
        <a href="/" class="inline-block bg-primary text-white font-bold px-8 py-3.5 rounded-xl shadow-lg hover:bg-primary-container transition">
          ابدأ التقديم على وظيفة <%= role.title %> في <%= city.city %>
        </a>
      </div>
    </section>

    <!-- الأسئلة الشائعة -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">الأسئلة الشائعة</h2>
      <div class="space-y-3">
        <details class="bg-white border border-slate-200 rounded-xl p-4">
          <summary class="font-semibold cursor-pointer text-primary">كم راتب <%= role.title %> في <%= city.city %>؟</summary>
          <p class="mt-2 text-slate-600 leading-loose"><%= role.faqSalary %></p>
        </details>
        <details class="bg-white border border-slate-200 rounded-xl p-4">
          <summary class="font-semibold cursor-pointer text-primary">هل التقديم على وظائف الحراسة في <%= city.city %> مجاني؟</summary>
          <p class="mt-2 text-slate-600 leading-loose">نعم، التقديم إلكتروني ومجاني تماماً عبر موقع أرتال، ولا توجد أي رسوم على المتقدمين.</p>
        </details>
        <details class="bg-white border border-slate-200 rounded-xl p-4">
          <summary class="font-semibold cursor-pointer text-primary">ما شروط القبول كـ<%= role.title %> في <%= city.city %>؟</summary>
          <p class="mt-2 text-slate-600 leading-loose"><%= role.faqRequirements %></p>
        </details>
        <details class="bg-white border border-slate-200 rounded-xl p-4">
          <summary class="font-semibold cursor-pointer text-primary">هل يوجد توظيف فوري لوظائف <%= role.title %> في <%= city.city %>؟</summary>
          <p class="mt-2 text-slate-600 leading-loose">نعم، نستقبل طلبات التوظيف بشكل مستمر في <%= city.city %> وتتم مراجعتها أولاً بأول، مع إمكانية المباشرة السريعة حسب احتياج المواقع مثل <%= city.sites[0] %>.</p>
        </details>
        <details class="bg-white border border-slate-200 rounded-xl p-4">
          <summary class="font-semibold cursor-pointer text-primary">هل تتطلب وظيفة <%= role.title %> في <%= city.city %> خبرة سابقة؟</summary>
          <p class="mt-2 text-slate-600 leading-loose"><%= role.faqExperience %></p>
        </details>
      </div>
    </section>

    <!-- وظائف أخرى في نفس المدينة -->
    <% if (otherRoles && otherRoles.length) { %>
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">وظائف أخرى في <%= city.city %></h2>
      <div class="flex flex-wrap gap-2">
        <% otherRoles.forEach(r => { %>
          <a href="<%= r.url %>" class="text-sm bg-white border border-slate-200 hover:border-primary hover:text-primary rounded-full px-4 py-2 transition">وظائف <%= r.title %> في <%= city.city %></a>
        <% }) %>
      </div>
    </section>
    <% } %>

    <!-- مدن أخرى — لنفس الوظيفة، فلا نرسل الزائر لصفحة غير موجودة -->
    <section>
      <h2 class="text-2xl font-bold text-primary mb-4">وظائف <%= role.title %> في مدن أخرى</h2>
      <div class="flex flex-wrap gap-2">
        <% roleCities.filter(c => c.slug !== city.slug).forEach(c => { %>
          <a href="/jobs/<%= c.slug %><%= roleSeg %>" class="text-sm bg-white border border-slate-200 hover:border-primary hover:text-primary rounded-full px-4 py-2 transition">وظائف <%= role.title %> <%= c.city %></a>
        <% }) %>
      </div>
    </section>
  </main>

  <!-- Footer + سحابة الكلمات المفتاحية -->
  <footer class="bg-primary text-white pt-12 pb-8">
    <div class="max-w-5xl mx-auto px-6">
      <p class="font-bold mb-5 text-center">روابط سريعة — وظائف الحراسة الأمنية في السعودية</p>
      <div class="flex flex-wrap justify-center gap-2 mb-8">
        <% cities.forEach(c => { %>
          <a href="/jobs/<%= c.slug %>" class="text-xs bg-white/10 hover:bg-white/20 rounded-full px-3 py-1.5 transition">وظائف حارس أمن <%= c.city %></a>
        <% }) %>
        <a href="/" class="text-xs bg-white/10 hover:bg-white/20 rounded-full px-3 py-1.5 transition">تقديم وظائف حراسة أمنية</a>
        <a href="/" class="text-xs bg-white/10 hover:bg-white/20 rounded-full px-3 py-1.5 transition">توظيف حراسات أمنية مدنية</a>
        <a href="/" class="text-xs bg-white/10 hover:bg-white/20 rounded-full px-3 py-1.5 transition">شركة حراسات أمنية توظيف</a>
        <a href="/" class="text-xs bg-white/10 hover:bg-white/20 rounded-full px-3 py-1.5 transition">راتب حارس أمن في السعودية</a>
      </div>
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <% socialLinks.forEach(s => { %>
          <a href="<%= s.url %>" target="_blank" rel="noopener" class="bg-white/10 hover:bg-white/20 rounded-full px-4 py-2 text-sm transition"><%= s.name %></a>
        <% }) %>
      </div>
      <!-- تطبيق الموظفين (للحراس والكوادر بعد القبول) -->
      <div class="text-center mb-8">
        <p class="text-sm text-slate-300 mb-3">تطبيق أرتال للموظفين — للحراس والكوادر</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="<%= appLinks[0] %>" target="_blank" rel="noopener" class="bg-white/10 hover:bg-white/20 rounded-lg px-4 py-2 text-sm transition">📱 تطبيق أندرويد</a>
          <a href="<%= appLinks[1] %>" target="_blank" rel="noopener" class="bg-white/10 hover:bg-white/20 rounded-lg px-4 py-2 text-sm transition">🍏 تطبيق آيفون</a>
        </div>
      </div>
      <p class="text-center text-slate-300 text-sm border-t border-white/10 pt-6">© 2026 شركة أرتال للحراسات الأمنية المدنية الخاصة. جميع الحقوق محفوظة.</p>
    </div>
  </footer>
  <script src="/js/attribution.js"></script>
</body>
</html>
