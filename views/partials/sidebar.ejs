<aside class="fixed right-0 top-0 h-full w-64 bg-[#001736] flex flex-col z-40 shadow-2xl">
  <!-- Brand -->
  <div class="px-5 py-5 border-b border-white/10">
    <div class="bg-white rounded-xl px-4 py-2.5 flex items-center justify-center shadow-md">
      <img src="/images/icon.png" alt="أرتال" class="h-9 w-auto object-contain">
    </div>
    <div class="text-center text-[#7594ca] text-[10px] tracking-widest mt-2.5">نظام التوظيف</div>
  </div>

  <!-- Nav -->
  <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
    <a href="/admin/dashboard"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all
              <%= currentPage === 'dashboard' ? 'bg-white/10 text-white' : 'text-[#7594ca] hover:bg-white/5 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">dashboard</span>
      <span>لوحة التحكم</span>
    </a>
    <a href="/admin/applicants"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all
              <%= currentPage === 'applicants' ? 'bg-white/10 text-white' : 'text-[#7594ca] hover:bg-white/5 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">group</span>
      <span>المتقدمون</span>
    </a>

    <div class="border-t border-white/10 my-3"></div>
    <a href="/admin/performance"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all
              <%= currentPage === 'performance' ? 'bg-white/10 text-white' : 'text-[#7594ca] hover:bg-white/5 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">insights</span>
      <span>أداء الموظفين</span>
    </a>
    <a href="/admin/audit"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all
              <%= currentPage === 'audit' ? 'bg-white/10 text-white' : 'text-[#7594ca] hover:bg-white/5 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">policy</span>
      <span>سجل التدقيق</span>
    </a>
    <% if (locals.adminRole === 'manager') { %>
    <a href="/admin/users"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all
              <%= currentPage === 'users' ? 'bg-white/10 text-white' : 'text-[#7594ca] hover:bg-white/5 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">manage_accounts</span>
      <span>المستخدمون</span>
    </a>
    <a href="/admin/settings"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium transition-all
              <%= currentPage === 'settings' ? 'bg-white/10 text-white' : 'text-[#7594ca] hover:bg-white/5 hover:text-white' %>">
      <span class="material-symbols-outlined text-lg">settings</span>
      <span>الإعدادات</span>
    </a>
    <% } %>

    <div class="border-t border-white/10 my-3"></div>
    <a href="https://apply.artalsecurity.com" target="_blank"
       class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-[#7594ca] hover:bg-white/5 hover:text-white transition-all">
      <span class="material-symbols-outlined text-lg">open_in_new</span>
      <span>صفحة التقديم</span>
    </a>
  </nav>

  <!-- User -->
  <div class="px-4 pb-6 border-t border-white/10 pt-4">
    <div class="flex items-center gap-3 px-3 py-2 mb-2">
      <div class="w-8 h-8 rounded-full bg-[#ffdf9e]/20 flex items-center justify-center flex-shrink-0">
        <span class="material-symbols-outlined text-[#ffdf9e] text-base" style="font-variation-settings:'FILL' 1">manage_accounts</span>
      </div>
      <div>
        <span class="text-white text-sm font-medium block"><%= locals.adminName || adminUser %></span>
        <span class="text-[10px] text-[#7594ca] block truncate max-w-[130px]"><%= adminUser %></span>
        <span class="text-[10px] <%= locals.adminRole === 'manager' ? 'text-[#ffdf9e]' : 'text-[#7594ca]' %>">
          <%= locals.adminRole === 'manager' ? 'مدير' : 'موظف' %>
        </span>
      </div>
    </div>
    <a href="/admin/logout"
       class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm text-red-400 hover:bg-red-900/20 hover:text-red-300 transition-all">
      <span class="material-symbols-outlined text-base">logout</span>
      <span>تسجيل الخروج</span>
    </a>
  </div>
</aside>
