<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>لوحة التحكم — أرتال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f2f4f6; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
  </style>
</head>
<body class="text-[#191c1e]">
<%- include('partials/sidebar', { currentPage: 'dashboard' }) %>

<div class="mr-64 min-h-screen">
  <!-- Top bar -->
  <header class="bg-white border-b border-[#eceef0] px-8 py-5 flex items-center justify-between sticky top-0 z-30">
    <div>
      <h1 class="text-xl font-bold text-[#001736]">لوحة التحكم</h1>
      <p class="text-xs text-[#43474f] mt-0.5">نظرة عامة على حركة التوظيف</p>
    </div>
    <a href="/admin/applicants"
       class="bg-[#001736] text-white text-sm font-medium px-5 py-2.5 rounded-xl flex items-center gap-2 hover:bg-[#002b5b] transition-colors">
      <span class="material-symbols-outlined text-base">group</span>
      عرض المتقدمين
    </a>
  </header>

  <main class="p-8 space-y-8">

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="bg-white rounded-2xl p-6 col-span-2 md:col-span-1 flex items-center gap-4">
        <div class="w-14 h-14 rounded-xl bg-[#001736] flex items-center justify-center flex-shrink-0">
          <span class="material-symbols-outlined text-white text-2xl" style="font-variation-settings:'FILL' 1">group</span>
        </div>
        <div>
          <div class="text-3xl font-extrabold text-[#001736]"><%= stats.total %></div>
          <div class="text-xs text-[#43474f] mt-0.5">إجمالي المتقدمين</div>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-5 flex items-center gap-3">
        <div class="w-3 h-3 rounded-full bg-blue-500 flex-shrink-0"></div>
        <div>
          <div class="text-2xl font-bold text-[#001736]"><%= stats.pending %></div>
          <div class="text-xs text-[#43474f]">جديد</div>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-5 flex items-center gap-3">
        <div class="w-3 h-3 rounded-full bg-purple-500 flex-shrink-0"></div>
        <div>
          <div class="text-2xl font-bold text-[#001736]"><%= stats.shortlisted %></div>
          <div class="text-xs text-[#43474f]">مرشح للمقابلة</div>
        </div>
      </div>
      <div class="bg-white rounded-2xl p-5 flex items-center gap-3">
        <div class="w-3 h-3 rounded-full bg-green-500 flex-shrink-0"></div>
        <div>
          <div class="text-2xl font-bold text-[#001736]"><%= stats.hired %></div>
          <div class="text-xs text-[#43474f]">تم التعيين</div>
        </div>
      </div>
    </div>

    <!-- Status Breakdown + City Chart -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

      <!-- Pipeline status -->
      <div class="bg-white rounded-2xl p-6">
        <h2 class="font-bold text-[#001736] mb-5 text-base">توزيع الحالات</h2>
        <div class="space-y-3">
          <% const statusRows = [
            { key:'pending',     label:'جديد',              color:'bg-blue-500',   count: stats.pending },
            { key:'reviewed',    label:'قيد المراجعة',      color:'bg-yellow-400', count: stats.reviewed },
            { key:'shortlisted', label:'مرشح للمقابلة',    color:'bg-purple-500', count: stats.shortlisted },
            { key:'interviewed', label:'تمت المقابلة',      color:'bg-orange-400', count: stats.interviewed },
            { key:'hired',       label:'تم التعيين',        color:'bg-green-500',  count: stats.hired },
            { key:'on_hold',     label:'معلق',              color:'bg-gray-400',   count: stats.on_hold },
            { key:'rejected',    label:'مرفوض',             color:'bg-red-500',    count: stats.rejected },
          ]; %>
          <% statusRows.forEach(s => { %>
          <div class="flex items-center gap-3">
            <span class="text-xs text-[#43474f] w-28 text-left flex-shrink-0"><%= s.label %></span>
            <div class="flex-1 bg-[#f2f4f6] rounded-full h-2">
              <% const pct = stats.total > 0 ? Math.round((s.count / stats.total) * 100) : 0; %>
              <div class="<%= s.color %> h-2 rounded-full transition-all" style="width:<%= pct %>%"></div>
            </div>
            <span class="text-sm font-bold text-[#001736] w-8 text-center flex-shrink-0"><%= s.count %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- By City -->
      <div class="bg-white rounded-2xl p-6">
        <h2 class="font-bold text-[#001736] mb-5 text-base">توزيع المدن</h2>
        <% if (byCity.length === 0) { %>
          <div class="text-[#43474f] text-sm text-center py-8">لا توجد بيانات بعد</div>
        <% } else { %>
        <div class="space-y-3">
          <% const maxCity = byCity[0] ? byCity[0].count : 1; %>
          <% byCity.forEach(c => { %>
          <div class="flex items-center gap-3">
            <span class="text-xs text-[#43474f] w-24 flex-shrink-0 truncate"><%= c.city || 'غير محدد' %></span>
            <div class="flex-1 bg-[#f2f4f6] rounded-full h-2">
              <div class="bg-[#001736] h-2 rounded-full"
                   style="width:<%= Math.round((c.count / maxCity) * 100) %>%"></div>
            </div>
            <span class="text-sm font-bold text-[#001736] w-8 text-center flex-shrink-0"><%= c.count %></span>
          </div>
          <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Recent Applications -->
    <div class="bg-white rounded-2xl p-6">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-bold text-[#001736] text-base">آخر الطلبات</h2>
        <a href="/admin/applicants" class="text-xs text-[#405f91] hover:underline">عرض الكل</a>
      </div>
      <% if (recent.length === 0) { %>
        <div class="text-[#43474f] text-sm text-center py-8">لا توجد طلبات بعد</div>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-[#43474f] text-xs border-b border-[#f2f4f6]">
              <th class="text-right pb-3 font-semibold">الاسم</th>
              <th class="text-right pb-3 font-semibold">المدينة</th>
              <th class="text-right pb-3 font-semibold">الحالة</th>
              <th class="text-right pb-3 font-semibold">التاريخ</th>
              <th class="pb-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#f2f4f6]">
            <% recent.forEach(a => { %>
            <% const sm = STATUS_META[a.status] || { label: a.status, color: 'gray' }; %>
            <% const colorMap = { blue:'bg-blue-100 text-blue-700', yellow:'bg-yellow-100 text-yellow-700',
                                  purple:'bg-purple-100 text-purple-700', orange:'bg-orange-100 text-orange-700',
                                  green:'bg-green-100 text-green-700', gray:'bg-gray-100 text-gray-700',
                                  red:'bg-red-100 text-red-700' }; %>
            <tr class="hover:bg-[#f8f9fb] transition-colors">
              <td class="py-3 font-medium"><%= a.full_name %></td>
              <td class="py-3 text-[#43474f]"><%= a.city || '—' %></td>
              <td class="py-3">
                <span class="px-2.5 py-1 rounded-full text-xs font-semibold <%= colorMap[sm.color] %>">
                  <%= sm.label %>
                </span>
              </td>
              <td class="py-3 text-[#43474f] text-xs"><%= new Date(a.created_at).toLocaleDateString('ar-SA') %></td>
              <td class="py-3">
                <a href="/admin/applicants/<%= a.id %>" class="text-[#405f91] hover:underline text-xs">عرض</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </main>
</div>
</body>
</html>
