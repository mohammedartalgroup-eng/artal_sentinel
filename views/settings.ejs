<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>الإعدادات — أرطال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f2f4f6; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .field input, .field textarea {
      width: 100%; background: white; border: 1px solid #e0e3e5;
      border-radius: 0.75rem; padding: 0.75rem 1rem; font-size: 0.875rem;
      outline: none; transition: border-color 0.15s; font-family: 'Inter', sans-serif;
    }
    .field input:focus, .field textarea:focus { border-color: #7594ca; box-shadow: 0 0 0 3px rgba(117,148,202,0.15); }
  </style>
</head>
<body class="text-[#191c1e]">
<%- include('partials/sidebar', { currentPage: 'settings' }) %>

<div class="mr-64 min-h-screen">
  <!-- Top bar -->
  <header class="bg-white border-b border-[#eceef0] px-8 py-5 sticky top-0 z-30">
    <h1 class="text-xl font-bold text-[#001736]">الإعدادات</h1>
    <p class="text-xs text-[#43474f] mt-0.5">إدارة بيانات النظام وبيانات التواصل</p>
  </header>

  <main class="p-8 max-w-2xl space-y-6">

    <!-- Success banners -->
    <% if (success === '1') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3.5 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span>
      تم حفظ الإعدادات بنجاح.
    </div>
    <% } %>
    <% if (success === '2') { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3.5 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span>
      تم تغيير كلمة المرور بنجاح.
    </div>
    <% } %>
    <% if (typeof passwordError !== 'undefined' && passwordError) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-3.5 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">error</span>
      <%= passwordError %>
    </div>
    <% } %>

    <!-- Contact Info -->
    <div class="bg-white rounded-2xl p-7">
      <h2 class="font-bold text-[#001736] text-base mb-1 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">contact_phone</span>
        بيانات التواصل
      </h2>
      <p class="text-xs text-[#43474f] mb-6">تظهر هذه البيانات في صفحة التأكيد التي يراها المتقدم بعد التسجيل.</p>

      <form method="POST" action="/admin/settings" class="space-y-5">
        <div class="field">
          <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5">اسم الشركة</label>
          <input type="text" name="company_name" value="<%= settings.company_name %>" placeholder="Artal Security Guards">
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="field">
            <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5 flex items-center gap-1.5">
              <span class="material-symbols-outlined text-sm">call</span>
              رقم الهاتف
            </label>
            <input type="text" name="phone" value="<%= settings.phone %>" placeholder="+966 500 000 000" dir="ltr">
          </div>
          <div class="field">
            <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5 flex items-center gap-1.5">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 text-[#25D366]">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              واتساب
            </label>
            <input type="text" name="whatsapp" value="<%= settings.whatsapp || '' %>" placeholder="+966 500 000 000" dir="ltr">
          </div>
        </div>
        <div class="field">
          <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5 flex items-center gap-1.5">
            <span class="material-symbols-outlined text-sm">mail</span>
            البريد الإلكتروني
          </label>
          <input type="email" name="email" value="<%= settings.email %>" placeholder="recruitment@example.com" dir="ltr">
        </div>
        <div class="field">
          <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5 flex items-center gap-1.5">
            <span class="material-symbols-outlined text-sm">location_on</span>
            العنوان (يُستخدم لرابط الخريطة)
          </label>
          <input type="text" name="address" value="<%= settings.address %>" placeholder="الرياض، المملكة العربية السعودية">
        </div>

        <!-- Accepting applications toggle -->
        <div class="flex items-center justify-between p-4 bg-[#f8f9fb] rounded-xl">
          <div>
            <div class="text-sm font-semibold text-[#001736]">استقبال الطلبات</div>
            <div class="text-xs text-[#43474f] mt-0.5">عند الإيقاف، ستظهر صفحة "التوظيف متوقف مؤقتاً"</div>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="accepting_applications" value="true"
                   class="sr-only peer"
                   <%= settings.accepting_applications === 'true' ? 'checked' : '' %>>
            <div class="w-12 h-6 bg-[#e0e3e5] peer-focus:outline-none rounded-full peer
                        peer-checked:after:translate-x-full peer-checked:after:border-white
                        after:content-[''] after:absolute after:top-[2px] after:right-[2px]
                        after:bg-white after:border-gray-300 after:border after:rounded-full
                        after:h-5 after:w-5 after:transition-all peer-checked:bg-[#001736]"></div>
          </label>
        </div>

        <button type="submit"
                class="w-full bg-[#001736] text-white font-bold py-3.5 rounded-xl hover:bg-[#002b5b] transition-colors flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-base">save</span>
          حفظ الإعدادات
        </button>
      </form>
    </div>

    <!-- Change Password -->
    <div class="bg-white rounded-2xl p-7">
      <h2 class="font-bold text-[#001736] text-base mb-1 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">lock_reset</span>
        تغيير كلمة المرور
      </h2>
      <p class="text-xs text-[#43474f] mb-6">كلمة المرور الجديدة يجب أن تكون 8 أحرف على الأقل.</p>

      <form method="POST" action="/admin/settings/password" class="space-y-5">
        <div class="field">
          <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5">كلمة المرور الحالية</label>
          <input type="password" name="current_password" required autocomplete="current-password">
        </div>
        <div class="field">
          <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5">كلمة المرور الجديدة</label>
          <input type="password" name="new_password" required minlength="8" autocomplete="new-password">
        </div>
        <div class="field">
          <label class="block text-xs text-[#43474f] font-semibold uppercase tracking-wider mb-1.5">تأكيد كلمة المرور</label>
          <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password">
        </div>
        <button type="submit"
                class="w-full bg-[#002b5b] text-white font-bold py-3.5 rounded-xl hover:bg-[#003a7a] transition-colors flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-base">lock_reset</span>
          تغيير كلمة المرور
        </button>
      </form>
    </div>

    <!-- System Info -->
    <div class="bg-white rounded-2xl p-7">
      <h2 class="font-bold text-[#001736] text-base mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">info</span>
        معلومات النظام
      </h2>
      <div class="space-y-3 text-sm">
        <div class="flex justify-between items-center py-2 border-b border-[#f2f4f6]">
          <span class="text-[#43474f]">الإصدار</span>
          <span class="font-mono text-[#001736]">1.0.0</span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-[#f2f4f6]">
          <span class="text-[#43474f]">المستخدم الحالي</span>
          <span class="font-medium text-[#001736]"><%= adminUser %></span>
        </div>
        <div class="flex justify-between items-center py-2">
          <span class="text-[#43474f]">حالة استقبال الطلبات</span>
          <% if (settings.accepting_applications === 'true') { %>
          <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">مفعّل</span>
          <% } else { %>
          <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">موقوف</span>
          <% } %>
        </div>
      </div>
    </div>

  </main>
</div>
</body>
</html>
