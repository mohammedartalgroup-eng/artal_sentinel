<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>إدارة المدن — أرتال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f2f4f6; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .city-row { transition: background 0.12s; }
    .city-row:hover { background: #f8f9fb; }
  </style>
</head>
<body class="text-[#191c1e]">
<%- include('partials/sidebar', { currentPage: 'cities' }) %>

<div class="lg:mr-64 min-h-screen pt-14 lg:pt-0">

  <!-- Top bar -->
  <header class="bg-white border-b border-[#eceef0] px-4 lg:px-8 py-4 lg:py-5 sticky top-14 lg:top-0 z-30 flex items-center justify-between">
    <div>
      <h1 class="text-xl font-bold text-[#001736]">إدارة المدن</h1>
      <p class="text-xs text-[#43474f] mt-0.5">تحكم في المدن التي يراها المتقدم في نموذج التسجيل</p>
    </div>
    <span class="bg-[#001736]/10 text-[#001736] text-sm font-bold px-4 py-1.5 rounded-full">
      <%= cities.length %> مدينة
    </span>
  </header>

  <main class="p-4 lg:p-8 max-w-2xl space-y-6">

    <!-- Success / Error banners -->
    <% if (success) { %>
    <div class="bg-green-50 border border-green-200 text-green-700 rounded-xl px-5 py-3.5 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">check_circle</span>
      <%= success %>
    </div>
    <% } %>
    <% if (error) { %>
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-3.5 flex items-center gap-2 text-sm">
      <span class="material-symbols-outlined text-base">error</span>
      <%= error %>
    </div>
    <% } %>

    <!-- Add city form -->
    <div class="bg-white rounded-2xl p-6">
      <h2 class="font-bold text-[#001736] text-base mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">add_location</span>
        إضافة مدينة جديدة
      </h2>
      <form method="POST" action="/admin/cities" class="flex gap-3">
        <input type="text" name="name" placeholder="اسم المدينة أو المنطقة"
               required maxlength="60"
               class="flex-1 bg-[#f2f4f6] border border-[#e0e3e5] rounded-xl px-4 py-3 text-sm outline-none focus:border-[#7594ca] focus:ring-2 focus:ring-[#7594ca]/20 transition-all">
        <button type="submit"
                class="bg-[#001736] text-white font-bold px-6 py-3 rounded-xl hover:bg-[#002b5b] transition-colors flex items-center gap-2 text-sm whitespace-nowrap">
          <span class="material-symbols-outlined text-base">add</span>
          إضافة
        </button>
      </form>
    </div>

    <!-- Cities list -->
    <div class="bg-white rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-[#f2f4f6] flex items-center justify-between">
        <h2 class="font-bold text-[#001736] text-base flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">location_city</span>
          قائمة المدن
        </h2>
        <span class="text-xs text-[#43474f]">الترتيب من الأعلى يظهر أولاً في النموذج</span>
      </div>

      <% if (cities.length === 0) { %>
      <div class="text-center py-16 text-[#43474f]">
        <span class="material-symbols-outlined text-5xl text-[#c0c8d2] mb-3 block">location_off</span>
        <p class="font-medium">لا توجد مدن مضافة بعد</p>
        <p class="text-xs mt-1">أضف مدينة من النموذج أعلاه</p>
      </div>
      <% } else { %>
      <ul>
        <% cities.forEach((city, index) => { %>
        <li class="city-row flex items-center gap-4 px-6 py-3.5 border-b border-[#f2f4f6] last:border-b-0">

          <!-- Rank number -->
          <span class="w-7 h-7 rounded-full bg-[#f2f4f6] text-[#43474f] text-xs font-bold flex items-center justify-center flex-shrink-0">
            <%= index + 1 %>
          </span>

          <!-- City name -->
          <span class="material-symbols-outlined text-[#7594ca] text-lg flex-shrink-0"
                style="font-variation-settings:'FILL' 1">location_on</span>
          <span class="flex-1 font-medium text-[#001736] text-sm"><%= city.name %></span>

          <!-- Applicant count -->
          <% if (city.applicant_count > 0) { %>
          <span class="text-xs text-[#43474f] bg-[#f2f4f6] px-2.5 py-1 rounded-full">
            <%= city.applicant_count %> متقدم
          </span>
          <% } %>

          <!-- Up / Down / Delete -->
          <div class="flex items-center gap-1">
            <!-- Up -->
            <% if (index > 0) { %>
            <form method="POST" action="/admin/cities/<%= city.id %>/up">
              <button type="submit" title="تحريك لأعلى"
                      class="w-8 h-8 rounded-lg text-[#43474f] hover:bg-[#f2f4f6] hover:text-[#001736] transition-colors flex items-center justify-center">
                <span class="material-symbols-outlined text-base">keyboard_arrow_up</span>
              </button>
            </form>
            <% } else { %>
            <div class="w-8 h-8"></div>
            <% } %>

            <!-- Down -->
            <% if (index < cities.length - 1) { %>
            <form method="POST" action="/admin/cities/<%= city.id %>/down">
              <button type="submit" title="تحريك لأسفل"
                      class="w-8 h-8 rounded-lg text-[#43474f] hover:bg-[#f2f4f6] hover:text-[#001736] transition-colors flex items-center justify-center">
                <span class="material-symbols-outlined text-base">keyboard_arrow_down</span>
              </button>
            </form>
            <% } else { %>
            <div class="w-8 h-8"></div>
            <% } %>

            <!-- Delete -->
            <form method="POST" action="/admin/cities/<%= city.id %>/delete"
                  onsubmit="return confirm('حذف مدينة «<%= city.name %>»؟\nالمتقدمون الموجودون لن يتأثروا.')">
              <button type="submit" title="حذف"
                      class="w-8 h-8 rounded-lg text-red-400 hover:bg-red-50 hover:text-red-600 transition-colors flex items-center justify-center">
                <span class="material-symbols-outlined text-base">delete</span>
              </button>
            </form>
          </div>

        </li>
        <% }) %>
      </ul>
      <% } %>
    </div>

    <!-- Info note -->
    <div class="bg-blue-50 border border-blue-100 rounded-xl px-5 py-3.5 flex gap-3 text-sm text-blue-700">
      <span class="material-symbols-outlined text-base flex-shrink-0 mt-0.5">info</span>
      <p>أي تغيير يظهر فوراً لكل من يفتح صفحة التقديم. المتقدمون المسجّلون مسبقاً لن تتغير مدنهم.</p>
    </div>

  </main>
</div>
</body>
</html>
