<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>سجل التدقيق — أرتال Sentinel</title>
  <link rel="icon" type="image/png" href="/images/icon.png">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f2f4f6; }
    h1,h2,h3 { font-family: 'Manrope', sans-serif; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    select, input[type="text"], input[type="date"] {
      background: white; border: 1px solid #e0e3e5; border-radius: 0.75rem;
      padding: 0.5rem 0.75rem; font-size: 0.875rem; width: 100%;
      outline: none; transition: border-color 0.15s;
    }
    select:focus, input:focus { border-color: #7594ca; }
    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 600; white-space: nowrap; }
  </style>
</head>
<body class="text-[#191c1e]">
<%- include('partials/sidebar', { currentPage: 'audit' }) %>

<div class="mr-64 min-h-screen">

  <!-- Top bar -->
  <header class="bg-white border-b border-[#eceef0] px-8 py-5 flex items-center justify-between sticky top-0 z-30">
    <div class="flex items-center gap-3">
      <% if (filters.applicant_id) { %>
      <a href="/admin/applicants/<%= filters.applicant_id %>"
         class="text-[#43474f] hover:text-[#001736] transition-colors">
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
      <% } %>
      <div>
        <h1 class="text-xl font-bold text-[#001736]">سجل التدقيق</h1>
        <p class="text-xs text-[#43474f] mt-0.5">
          إجمالي السجلات: <strong><%= total %></strong>
          <% if (filters.applicant_id && applicantName) { %>
          &nbsp;·&nbsp;
          <span class="text-[#405f91] font-semibold">
            <span class="material-symbols-outlined text-xs align-middle">person_search</span>
            مفلتر لـ: <%= applicantName %>
          </span>
          <% } %>
        </p>
      </div>
    </div>
    <div class="flex items-center gap-2 text-xs text-[#43474f]">
      <span class="material-symbols-outlined text-base text-[#7594ca]">verified_user</span>
      <span>جميع العمليات مسجّلة تلقائياً</span>
    </div>
  </header>

  <main class="p-8 space-y-6">

    <!-- Filter Panel -->
    <form method="GET" action="/admin/audit">
      <div class="bg-white rounded-2xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-bold text-[#001736] text-sm flex items-center gap-2">
            <span class="material-symbols-outlined text-base">filter_list</span>
            الفلترة والبحث
          </h2>
          <a href="/admin/audit" class="text-xs text-[#405f91] hover:underline flex items-center gap-1">
            <span class="material-symbols-outlined text-sm">refresh</span>
            إعادة تعيين
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
          <!-- User filter -->
          <div>
            <label class="block text-xs font-medium text-[#43474f] mb-1.5">المستخدم</label>
            <select name="user">
              <option value="">جميع المستخدمين</option>
              <% users.forEach(u => { %>
                <option value="<%= u.username %>" <%= filters.user === u.username ? 'selected' : '' %>><%= u.username %></option>
              <% }) %>
            </select>
          </div>
          <!-- Action filter -->
          <div>
            <label class="block text-xs font-medium text-[#43474f] mb-1.5">نوع العملية</label>
            <select name="action">
              <option value="">جميع العمليات</option>
              <optgroup label="الدخول والخروج">
                <option value="login"          <%= filters.action === 'login'          ? 'selected' : '' %>>تسجيل الدخول</option>
                <option value="logout"         <%= filters.action === 'logout'         ? 'selected' : '' %>>تسجيل الخروج</option>
              </optgroup>
              <optgroup label="المتقدمون">
                <option value="status_change"  <%= filters.action === 'status_change'  ? 'selected' : '' %>>تغيير الحالة</option>
                <option value="rating_change"  <%= filters.action === 'rating_change'  ? 'selected' : '' %>>تغيير التقييم</option>
                <option value="note_add"       <%= filters.action === 'note_add'       ? 'selected' : '' %>>إضافة ملاحظة</option>
                <option value="note_edit"      <%= filters.action === 'note_edit'      ? 'selected' : '' %>>تعديل ملاحظة</option>
                <option value="note_delete"    <%= filters.action === 'note_delete'    ? 'selected' : '' %>>حذف ملاحظة</option>
                <option value="activity_delete" <%= filters.action === 'activity_delete' ? 'selected' : '' %>>حذف سجل نشاط</option>
                <option value="applicant_delete" <%= filters.action === 'applicant_delete' ? 'selected' : '' %>>حذف متقدم</option>
                <option value="export"         <%= filters.action === 'export'         ? 'selected' : '' %>>تصدير Excel</option>
              </optgroup>
              <optgroup label="المستخدمون">
                <option value="user_create"    <%= filters.action === 'user_create'    ? 'selected' : '' %>>إنشاء مستخدم</option>
                <option value="user_update"    <%= filters.action === 'user_update'    ? 'selected' : '' %>>تعديل مستخدم</option>
                <option value="user_delete"    <%= filters.action === 'user_delete'    ? 'selected' : '' %>>حذف مستخدم</option>
                <option value="password_reset" <%= filters.action === 'password_reset' ? 'selected' : '' %>>إعادة تعيين كلمة مرور</option>
              </optgroup>
              <optgroup label="الإعدادات">
                <option value="settings_update" <%= filters.action === 'settings_update' ? 'selected' : '' %>>تحديث الإعدادات</option>
                <option value="password_change" <%= filters.action === 'password_change' ? 'selected' : '' %>>تغيير كلمة مرور الأدمن</option>
              </optgroup>
            </select>
          </div>
          <!-- Date from -->
          <div>
            <label class="block text-xs font-medium text-[#43474f] mb-1.5">من تاريخ</label>
            <input type="date" name="date_from" value="<%= filters.date_from || '' %>">
          </div>
          <!-- Date to -->
          <div>
            <label class="block text-xs font-medium text-[#43474f] mb-1.5">إلى تاريخ</label>
            <input type="date" name="date_to" value="<%= filters.date_to || '' %>">
          </div>
        </div>
        <!-- preserve applicant_id filter across form submissions -->
        <% if (filters.applicant_id) { %>
        <input type="hidden" name="applicant_id" value="<%= filters.applicant_id %>">
        <% } %>
        <div class="mt-4 flex justify-end">
          <button type="submit"
            class="bg-[#001736] text-white text-sm font-medium px-6 py-2.5 rounded-xl hover:bg-[#002a5c] transition-colors flex items-center gap-2">
            <span class="material-symbols-outlined text-base">search</span>
            تطبيق الفلتر
          </button>
        </div>
      </div>
    </form>

    <!-- Logs Table -->
    <div class="bg-white rounded-2xl overflow-hidden shadow-sm">
      <% if (logs.length === 0) { %>
        <div class="py-20 text-center text-[#43474f]">
          <span class="material-symbols-outlined text-5xl text-[#cdd3db] block mb-3">history</span>
          <p class="text-sm">لا توجد سجلات تطابق الفلتر المحدد</p>
        </div>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-[#f7f8fa] border-b border-[#eceef0] text-xs font-semibold text-[#43474f]">
              <th class="px-5 py-3.5 text-right">#</th>
              <th class="px-5 py-3.5 text-right">المستخدم</th>
              <th class="px-5 py-3.5 text-right">العملية</th>
              <th class="px-5 py-3.5 text-right">الهدف</th>
              <th class="px-5 py-3.5 text-right">التفاصيل</th>
              <th class="px-5 py-3.5 text-right">عنوان IP</th>
              <th class="px-5 py-3.5 text-right">التاريخ والوقت</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#f0f1f3]">
            <% logs.forEach((log, i) => {
              const offset = (pageNum - 1) * 50;
              const rowNum = offset + i + 1;
            %>
            <tr class="hover:bg-[#f7f8fa] transition-colors">
              <!-- Row number -->
              <td class="px-5 py-3.5 text-[#8a9099] text-xs"><%= rowNum %></td>

              <!-- Username -->
              <td class="px-5 py-3.5">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-[#e8edf5] flex items-center justify-center flex-shrink-0">
                    <span class="material-symbols-outlined text-[#405f91] text-sm" style="font-variation-settings:'FILL' 1">person</span>
                  </div>
                  <span class="font-medium text-[#001736]"><%= log.username %></span>
                </div>
              </td>

              <!-- Action badge -->
              <td class="px-5 py-3.5">
                <%
                  const ACTION_MAP = {
                    login:            { label: 'دخول',              bg: '#e8f5e9', color: '#2e7d32' },
                    logout:           { label: 'خروج',              bg: '#f3f4f6', color: '#4b5563' },
                    status_change:    { label: 'تغيير حالة',        bg: '#fff8e1', color: '#f57f17' },
                    rating_change:    { label: 'تغيير تقييم',       bg: '#f3e5f5', color: '#7b1fa2' },
                    note_add:         { label: 'ملاحظة جديدة',      bg: '#e0f2fe', color: '#0277bd' },
                    note_edit:        { label: 'تعديل ملاحظة',      bg: '#e8f4fd', color: '#0369a1' },
                    note_delete:      { label: 'حذف ملاحظة',        bg: '#fff0f0', color: '#c62828' },
                    activity_delete:  { label: 'حذف سجل نشاط',     bg: '#fff0f0', color: '#b45309' },
                    applicant_delete: { label: 'حذف متقدم',         bg: '#fce4ec', color: '#c62828' },
                    export:           { label: 'تصدير Excel',       bg: '#e8f5e9', color: '#1b5e20' },
                    user_create:      { label: 'إنشاء مستخدم',      bg: '#e0f7fa', color: '#00695c' },
                    user_update:      { label: 'تعديل مستخدم',      bg: '#e8eaf6', color: '#283593' },
                    user_delete:      { label: 'حذف مستخدم',        bg: '#fce4ec', color: '#ad1457' },
                    password_reset:   { label: 'إعادة تعيين مرور', bg: '#fff3e0', color: '#e65100' },
                    settings_update:  { label: 'تحديث الإعدادات',   bg: '#e8eaf6', color: '#3949ab' },
                    password_change:  { label: 'تغيير مرور الأدمن', bg: '#fff3e0', color: '#bf360c' },
                  };
                  const a = ACTION_MAP[log.action] || { label: log.action, bg: '#f0f0f0', color: '#555' };
                %>
                <span class="badge" style="background:<%= a.bg %>; color:<%= a.color %>">
                  <%= a.label %>
                </span>
              </td>

              <!-- Target -->
              <td class="px-5 py-3.5">
                <% if (log.target_name) { %>
                  <% if (log.target_type === 'applicant' && log.target_id) { %>
                    <a href="/admin/applicants/<%= log.target_id %>"
                       class="text-[#405f91] hover:underline font-medium"><%= log.target_name %></a>
                  <% } else { %>
                    <span class="font-medium text-[#191c1e]"><%= log.target_name %></span>
                  <% } %>
                <% } else { %>
                  <span class="text-[#8a9099]">—</span>
                <% } %>
              </td>

              <!-- Details -->
              <td class="px-5 py-3.5 text-[#43474f] max-w-xs">
                <% if (log.details) { %>
                  <span class="text-xs"><%= log.details %></span>
                <% } else { %>
                  <span class="text-[#8a9099]">—</span>
                <% } %>
              </td>

              <!-- IP -->
              <td class="px-5 py-3.5">
                <span class="text-xs text-[#8a9099] font-mono"><%= log.ip || '—' %></span>
              </td>

              <!-- Date -->
              <td class="px-5 py-3.5 whitespace-nowrap text-xs text-[#43474f]">
                <%= fmtDateTime(log.created_at) %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="px-6 py-4 border-t border-[#eceef0] flex items-center justify-between">
        <span class="text-xs text-[#43474f]">
          صفحة <strong><%= pageNum %></strong> من <strong><%= totalPages %></strong>
          &nbsp;·&nbsp; <strong><%= total %></strong> سجل إجمالاً
        </span>
        <div class="flex items-center gap-1.5">
          <%
            const cleanFilters = Object.fromEntries(Object.entries(filters).filter(([,v]) => v));
            const qp = new URLSearchParams(cleanFilters);
            const prevPage = pageNum - 1;
            const nextPage = pageNum + 1;
          %>
          <% if (pageNum > 1) { %>
            <% qp.set('page', prevPage); %>
            <a href="/admin/audit?<%= qp.toString() %>"
               class="flex items-center gap-1 px-3 py-1.5 rounded-lg border border-[#e0e3e5] text-xs hover:bg-[#f2f4f6] transition-colors">
              <span class="material-symbols-outlined text-sm">chevron_right</span>
              السابقة
            </a>
          <% } %>

          <% for (let p = Math.max(1, pageNum - 2); p <= Math.min(totalPages, pageNum + 2); p++) { %>
            <% qp.set('page', p); %>
            <a href="/admin/audit?<%= qp.toString() %>"
               class="w-8 h-8 rounded-lg text-xs flex items-center justify-center transition-colors
                      <%= p === pageNum ? 'bg-[#001736] text-white' : 'border border-[#e0e3e5] hover:bg-[#f2f4f6]' %>">
              <%= p %>
            </a>
          <% } %>

          <% if (pageNum < totalPages) { %>
            <% qp.set('page', nextPage); %>
            <a href="/admin/audit?<%= qp.toString() %>"
               class="flex items-center gap-1 px-3 py-1.5 rounded-lg border border-[#e0e3e5] text-xs hover:bg-[#f2f4f6] transition-colors">
              التالية
              <span class="material-symbols-outlined text-sm">chevron_left</span>
            </a>
          <% } %>
        </div>
      </div>
      <% } %>

      <% } /* end logs.length > 0 */ %>
    </div>

  </main>
</div>
</body>
</html>
